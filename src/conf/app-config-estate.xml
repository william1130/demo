<?xml version="1.0" encoding="UTF-8"?>

<app-config encoding="UTF-8">
	<application-name>ATS LOG 查詢系統-MERCHANT</application-name>
	<resource-bundles>
		<app-resource bundle="app-message" />
		<web-resource bundle="web-message" />
	</resource-bundles>
	<user-profile class="proj.nccc.logsearch.user.ProjUserProfile">
		<user-info class="proj.nccc.logsearch.user.ProjUserInfo"
		default-user-id="test" default-user-name="Test" />
		<user-task class="com.edstw.nccc.user.NcccUserTask"/>
	</user-profile>
	<data-sources default-data-source-name="LogSearchJdbcLdssDS">
		<!-- name : DataSource於系統中所使用之名稱. -->
		<!-- Oracle -->
		<data-source name="LogSearchStoreJdbcDS">
			<jndi-name>jdbc/atslog_ems_ds</jndi-name>
		</data-source>
		<data-source name="LogTransJdbcDS">
			<jndi-name>jdbc/atslog_trans_ds</jndi-name>
		</data-source>
		<data-source name="LogSearchJdbcLdssDS">
			<jndi-name>jdbc/atslog_ldss_ds</jndi-name>
		</data-source>
	</data-sources>
	<jdbc-filter>
		<connection-filter>
			<filter class-name="com.edstw.sql.filter.ConnectionLogger" />
			<filter class-name="com.dxc.nccc.aplog.edstw.sql.ApLogConnectionFilter"/>
		</connection-filter>
		<statement-filter>
			<filter class-name="com.edstw.sql.filter.StatementLogger" />
		</statement-filter>
		<prepared-statement-filter>
			<filter class-name="com.edstw.sql.filter.PreparedStatementLogger" />
		</prepared-statement-filter>
		<callable-statement-filter>
			<filter class-name="com.edstw.sql.filter.CallableStatementLogger" />
		</callable-statement-filter>
	</jdbc-filter>
	<date-setting lenient="false">
		<!-- DateString的格式設定 -->
		<date-string input-pattern="yyyyMMdd" persist-pattern="yyyyMMdd"
			display-pattern="yyyyMMdd" />
		<date-time-string input-pattern="yyyyMMdd HH:mm:ss"
			persist-pattern="yyyyMMdd HH:mm:ss" display-pattern="yyyyMMdd HH:mm:ss" />
		<time-pattern>HH:mm:ss</time-pattern>
		<full-pattern>yyyyMMdd HH:mm:ss</full-pattern>
	</date-setting>
	
	<persistence transaction-manager-factory="com.edstw.persist.impl.PersistableManagerFactoryImpl">
		<transactional-resources
			default-transactional-resource-name="LogSearchJdbcLdssDSResource">
			<transactional-resource name="LogSearchJdbcLdssDSResource"
				class="com.edstw.persist.jdbc.impl.DataSourceTransactionalResource">
				<param name="dataSourceName" value="LogSearchJdbcLdssDS" />
			</transactional-resource>
		</transactional-resources>
		
		<dao-manager>
		</dao-manager>
		
		<store-manager store-manager-class="com.edstw.persist.jdbc.impl.JdbcStoreManagerImpl"
			transactional-resource-name="LogSearchJdbcLdssDSResource">
			<persistable class="com.edstw.nccc.sql.log.AccessLog">
				<store class="com.edstw.nccc.sql.log.AccessLogStore">
					<param name="accessLogTableName" value="" />
				</store>
			</persistable>
			
			<!-- aplog start -->	
			<persistable class="com.dxc.nccc.aplog.edstw.persist.LogMasterImpl">
				<store class="com.dxc.nccc.aplog.edstw.persist.LogMasterImplStore">
					<param name="tableName" value="LOG_MASTER"/>
				</store>
			</persistable>
			<persistable class="com.dxc.nccc.aplog.edstw.persist.LogDetailImpl">
				<store class="com.dxc.nccc.aplog.edstw.persist.LogDetailImplStore">
					<param name="tableName" value="LOG_DETAIL"/>
				</store>
			</persistable>
			<persistable class="com.dxc.nccc.aplog.edstw.persist.LogFunctionState">
				<store class="com.dxc.nccc.aplog.edstw.persist.LogFunctionStateStore">
					<param name="tableName" value="LOG_FUNCTION_STATS"/>
				</store>
			</persistable>
			<!-- aplog end -->
		</store-manager>
	</persistence>
	
	<services default-restricted-records="0" join-transaction-when-query="true">
		
		<!-- AP LOG -->
		<service serviceKey="query.logFunctionState" class="com.dxc.nccc.aplog.edstw.sql.LogFunctionStateQSImpl" />
		<service serviceKey="proc.logFunctionState" class="com.dxc.nccc.aplog.edstw.proc.LogFunctionStateProcImpl" />
		
		<service serviceKey="query.MfesUcsApplyCode"
			class="proj.nccc.logsearch.qs.MfesUcsApplyCodeQSImpl" >
			<param name="dataSourceName" value="LogSearchStoreJdbcDS" />
		</service>
		<service serviceKey="query.MfesUcsBatchHeader"
			class="proj.nccc.logsearch.qs.MfesUcsBatchHeaderQSImpl" >
			<param name="dataSourceName" value="LogTransJdbcDS" />
		</service>
		
		<!-- Echo Message -->
		<service serviceKey="proc.echoMessage" class="proj.nccc.logsearch.proc.EchoMessageProcImpl" />
		
	</services>	

	<beans>
		<bean bean-name="paramBean" bean-class="proj.nccc.logsearch.beans.ParamBeanEstm"
			factory-method="getInstance" />
	</beans>

	<tasks schedule-scan-period="60000" max-concurrent-instant-task="1"
		enable-schedule="true" instant-queue-class="com.edstw.task.InstantTaskQueue"
		schedule-queue-class="com.edstw.task.ScheduleTaskQueue">

	</tasks>
	<web-info>
		<script-folder folder="/scripts" />
		<css-folder folder="/css" />
		<image-folder folder="/images" />
	</web-info>

	<context-attribute>
		<attribute name="dateUtil" bean-class="com.edstw.util.DateUtil"
			factory-method="getInstance" />
		<attribute name="authManager"
			bean-class="com.edstw.nccc.security.NcccAuthorizationManager"
			factory-method="getInstance" />
		<attribute name="menu" bean-class="com.edstw.security.Menu" factory-method="getInstance" />
		<attribute ref-bean-name="paramBean" />
		<attribute name="projConfig" bean-class="proj.nccc.logsearch.ProjConfig"
			factory-method="getInstance" />
	</context-attribute>
	
	<!-- 設定各程式之權限. -->
	<authorization skip-authorization="false" class="com.edstw.nccc.security.NcccAuthorizationManager">
		<program id="ALL_FUN_LIST" name="清單列表: 改由token控制" non-ldap-func="true" ldap-func-id="A009">
			<function id="allFunList" name="ALLFunList" function-value="0">
			 	<action entry="true">/mfesUncloseStat.do</action>
			 </function>
		</program>
	</authorization>
	
	<!-- @{skipLdap}@ 設定menu. not-authorized : 設定未被授權的項目要如何顯示. 合法值為 : 'hide' : 隱藏不顯示. 'show' 
		: 顯示. 'disable' : 顯示, 但不能連結. -->
	<menu not-authorized="hide">
		<group name="NA">
			<item program-id="ALL_FUN_LIST" function-id="allFunList" /> 
		</group>
	</menu>
	<access-log class="com.edstw.nccc.sql.log.AccessLog" enable-query-log="false" enable-command-log="false" enable-update-log="false" enable-entry-log="false" ignore-system-query="false" ignore-system-update="false"
			 include-app-id="false" image-length="4000" value-separator="TAB" apply-to-all-table="false">
	</access-log>
	<customize-setting class="proj.nccc.logsearch.ProjConfig"
		config-file="/WEB-INF/conf/proj-config.xml" factory-method="getInstance" />
</app-config>
