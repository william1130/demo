	<context-attribute>
		<!-- 設定要置於ServletContext中的物件. 注意!!若為com.edstw.bean.BaseBean之子類別, 必須在<beans/>中設定, 
			才會自動呼叫該介面定義之函式. 於此定義之bean物件, 只會當成一般物件處理, 並且不會加入至BeanManager中. name : 用來在ServletContext中存放物件的key值. 
			bean-class : Bean類別. factory-method : 若bean-class指定之bean為singleton, 可在此指定其factory-method. 
			ref-bean-name : reference beans中設定之beanName, 若使用refBeanName時, 便無需bean-class的設定. 
			若沒有指定name, 則會以refBeanName為其名. -->
		<!-- 當直接以bean-class設定context-attribute中的一個物件時, 可以利用<param/>來設定參數, param同樣可以設定name及value屬性. 
			name : 變數名稱, 此變數名稱應對應至bean-class指定之class中的一變數名稱. value : 變數值. 會依實際類別中對應變數的型別自動做型別轉換. -->
		<attribute name="dateUtil" bean-class="com.edstw.util.DateUtil"
			factory-method="getInstance" />
		<attribute name="authManager"
			bean-class="com.edstw.nccc.security.NcccAuthorizationManager"
			factory-method="getInstance" />
		<attribute name="menu" bean-class="com.edstw.security.Menu" factory-method="getInstance" />
<!-- 		<attribute name="menu2" bean-class="com.edstw.security.Menu" factory-method="getInstance" /> -->
		<attribute ref-bean-name="paramBean" />
		<attribute name="projConfig" bean-class="proj.nccc.logsearch.ProjConfig"
			factory-method="getInstance" />
		<!-- <attribute name="constBean" bean-class="proj.nccc.logsearch.beans.ConstantsBean" 
			factory-method="getInstance"/> <attribute name="enumBean" bean-class="proj.nccc.logsearch.beans.EnumBean" 
			factory-method="getInstance"/> <attribute name="authManager" bean-class="proj.nccc.logsearch.security.AuthorizationManager" 
			factory-method="getInstance"/> <attribute name="menu" bean-class="proj.nccc.logsearch.security.Menu" 
			factory-method="getInstance"/> -->
