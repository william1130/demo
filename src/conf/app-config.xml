	<!-- 設定系統啟動時, 要預先載入之bean object. 系統中經常使用且可以共用之物件可以在此宣告. 系統啟動後, 裡面宣告的bean物件會以其name所指定的名稱存放在com.edstw.BeanManager中, 
		使用者可以直接取用. -->
	<beans>
		<!-- 定義Application中使用到之Bean物件, 若為com.edstw.bean.BaseBean之子類別, 則可以利用<param/>設定初始參數. 
			bean-name : 用來在BeanManager中存放物件的key值. bean-class : Bean類別. factory-method 
			: 若bean為singleton, 可在此指定其factory-method. -->
		<!-- 各個bean的設定中, 可以<param name="propName" value="propValue"/>來設定bean物件的參數, 
			若bean類別是繼承自com.edstw.bean.BaseBean, 則參數的設定會透過該類別的setParam介面設定, 若是一般的類別, 則name必須對應至該類別的一個property 
			name, value則會視該property之型別自動轉型. 此外, 若bean是繼承自com.edstw.bean.TaskBean, 則必須設定<task-info/>, 
			相關說明請參考<tasks/>中的說明. -->
		<bean bean-name="paramBean" bean-class="proj.nccc.logsearch.beans.ParamBean"
			factory-method="getInstance" />
		<bean bean-name="chipUtil" bean-class="proj.nccc.logsearch.parse.ChipUtil"
			factory-method="getInstance" />
		<bean bean-name="isoUtil" bean-class="proj.nccc.logsearch.parse.ISOUtil"
			factory-method="getInstance" />
	</beans>
	<!-- 設定Task, 在此設定之task, 均會以daemon的形式排程執行, 相關說明請參考TaskManager類別之說明. schedule-scan-period 
		: 設定多久掃描一次(ms)daemon task queue, 設定值應較實際排程之task的間隔時間小, 才能儘可能在最正確的時間執行task. 
		max-concurrent-instant-task : 系統中同時間執行之instant task的上限數目. instant task相關說明請參考TaskManager類別之說明 -->
	<tasks schedule-scan-period="60000" max-concurrent-instant-task="1"
		enable-schedule="true" instant-queue-class="com.edstw.task.InstantTaskQueue"
		schedule-queue-class="com.edstw.task.ScheduleTaskQueue">
		<!-- 設定task. class : task的類別. factory-method : 若task為singleton, 可在此指定其factory-method. 
			<task class="" factory-method=""> <!- 設定Task的TaskInfo task-id : task id task-name 
			: task-name -> <task-info task-id="" task-name=""> <!- 設定task的schedule start-at 
			: 第一次啟動時間. format必須為'yyyyMMdd HH:mm:ss', 若設定的時間發生在過去, 則會立即啟動. period-unit 
			: 間隔時間. task第二次以後之執行時間是依start-at所設定之時間加上間隔的時間. 若第二次以後的時間仍出現在過去, 則會依間隔時間的設定, 
			自動調整至系統日期之後, 避免連續執行. 此外, 間隔時間的設定, 也應考量task本身執行時間之長短, 若task執行時間超過間隔時間, 則該task將會不斷執行, 
			影響其他task的執行. period-type : 間隔時間單位類別, 合法值為'second', 'minute', 'hour', 'day', 
			'week', 'month'跟'year' repeat-count : 執行次數(含第一次). 若設定為0 , 代表不限次數. run-when-outdated 
			: 設定當start-at所設定的時間發生在過去時, 是否要於系統啟動時先執行一次 -> <schedule start-at="20050801 
			12:00:00" period-type="minute" period-unit="3" repeat-count="0"/> </task-info> 
			<!- 設定參數. name : 參數名稱, 必須對應至task中的一個property(必須有setXXX()介面). value : 參數值, 
			會依照實際task中該property的型別自動轉型. <param name="" value=""/> -> </task> -->
		<task class="com.edstw.task.bean.CacheableBeanTask">
