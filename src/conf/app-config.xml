	<!--  @{skipLdap}@設定access log的功能. class: 設定AccessLog的實際類別, 必須繼承自com.edstw.nccc.sql.log.AccessLog. 
		enable-query-log: 是否開啟query log的功能, 合法值為true/false, 代表開啟/關閉此功能. enable-update-log: 
		是否開啟update log的功能, 合法值為true/false, 代表開啟/關閉此功能. enable-entry-log: 是否開啟entry 
		log的功能(當使用者執行功能時會針對其執行的程式於進入點做log), 合法值為true/false, 代表開啟/關閉此功能, 若設為true, 
		仍要在web.xml中定義EntryLogFilter才能正確做log. ignore-system-query: 是否忽略system user的查詢動作. 
		ignore-system-update: 是否忽略system user的更新動作. include-app-id: log的資訊中是否包含application 
		id. image-length: 設定代表資料的image字串長度. 預設為4000. value-separator: 製作image字串時, 
		用來分隔不同欄位值的分隔字元, 'TAB'代表以tab字元為分隔字元. apply-to-all-table: access log的設定是否套用到所有table. 
		若為false, 則必須設定哪些table需要做access log, 若沒有設定table, 相當於關閉了access log的功能. 若為true, 
		則table的設定將會被忽略, 全部套用預設值. 但實際上會不會做log, 需視實作之程式有無符合做access log的規範. -->
		<access-log class="com.edstw.nccc.sql.log.AccessLog" enable-query-log="false" enable-command-log="false" enable-update-log="false" enable-entry-log="false" ignore-system-query="false" ignore-system-update="false"
			 include-app-id="false" image-length="4000" value-separator="TAB" apply-to-all-table="false">
	
	<!-- <access-log class="com.edstw.nccc.sql.log.AccessLog"
		enable-query-log="false" enable-update-log="false" enable-entry-log="false"
		ignore-system-query="true" ignore-system-update="true" include-app-id="false"
		image-length="4000" value-separator="TAB" apply-to-all-table="true"> -->
		<!-- 設定個別table的access log設定, 若apply-to-all-table為true時, 此設定會被忽略. table-name: 
			table name enable-query-log: 是否針對此table開啟query log功能, 但若access log的enable-query-log設定為false時, 
			此處即使設定也true也會被忽略. enable-update-log: 是否針對此table開啟update log功能, 但若access log的enable-update-log設定為false時, 
			此處即使設定也true也會被忽略. -->
		<!-- <table table-name="TMS_MEMV_CONTACT" enable-query-log="false" enable-update-log="false"/> -->
	</access-log>
	<customize-setting class="proj.nccc.logsearch.ProjConfig"
		config-file="/WEB-INF/conf/proj-config.xml" factory-method="getInstance" />
</app-config>
