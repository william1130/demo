<?xml version="1.0" encoding="UTF-8"?>

<!-- locale : 設定locale.若未設定locale, 則以系統預設值. variant : locale的variant. encoding 
	: 本系統預設之encoding, 系統中需要使用編碼功能時, 會以此為預設值, 若未設定, 預設值為MS950 -->
<app-config encoding="UTF-8">
	<application-name>ATS LOG 查詢系統</application-name>
	<resource-bundles>
		<!-- app-resource 用來設定系統訊息的resource, 設定後即可使用com.edstw.util.AppMessageBundle. -->
		<app-resource bundle="app-message" />
		<!-- web-resource 用來設定web訊息的resource, 設定後即可使用com.edstw.web.util.WebMessageBundle, 
			且JSTL即會自動以之為預設bundle. 此設定只在web application環境下使用. -->
		<web-resource bundle="web-message" />
	</resource-bundles>
	<user-profile class="proj.nccc.logsearch.user.ProjUserProfile">
		<user-info class="proj.nccc.logsearch.user.ProjUserInfo"
			default-user-id="test" default-user-name="Test" />
		<user-task class="com.edstw.nccc.user.NcccUserTask"
			max-history-records="4" />
	</user-profile>
	<data-sources default-data-source-name="LogSearchJdbcLdssDS">
		<!-- name : DataSource於系統中所使用之名稱. -->
		<!-- Oracle -->
		<data-source name="LogSearchStoreJdbcDS">
			<jndi-name>jdbc/atslog_store_ds</jndi-name>
		</data-source>
		<data-source name="LogSearchR6JdbcDS">
			<jndi-name>jdbc/atslog_R6_ds</jndi-name>
		</data-source>
		<data-source name="LogTransJdbcDS">
			<jndi-name>jdbc/atslog_trans_ds</jndi-name>
		</data-source>
		<data-source name="LogSearchJdbcLdssDS">
			<jndi-name>jdbc/atslog_ldss_ds</jndi-name>
		</data-source>
	</data-sources>
	<!-- 設定JDBC相關介面的filter, 目前共定義四種filter, 自行實作要覆寫之函式後在此設定即可: 為避免造成系統太大effort, 
		filter中所做之動作應儘可能簡單. ConnectionFilter StatementFilter PreparedStatementFilter 
		CallableStatementFilter -->
	<jdbc-filter>
		<!-- 各個filter下可設定 <filter class-name=""/> 指定實際之filter, filter之執行順序與設定順序有關, 
			愈早設定的filer會最晚被執行到. 故設定時需注意. -->
		<connection-filter>
			<filter class-name="com.edstw.sql.filter.ConnectionLogger" />
			<filter class-name="com.dxc.nccc.aplog.edstw.sql.ApLogConnectionFilter"/>
		</connection-filter>
		<statement-filter>
			<filter class-name="com.edstw.sql.filter.StatementLogger" />
		</statement-filter>
		<prepared-statement-filter>
			<filter class-name="com.edstw.sql.filter.PreparedStatementLogger" />
		</prepared-statement-filter>
		<callable-statement-filter>
			<filter class-name="com.edstw.sql.filter.CallableStatementLogger" />
		</callable-statement-filter>
	</jdbc-filter>
	<!-- 設定系統中使用的日期格式 lenient : parsing時是否使用寬鬆的條件, 但lenient即使設定為false, 部份字串在做parsing時仍有可能成功, 
		例如pattern為'yyyyMMdd'時, '2006029'會parsing成2006/2/9 -->
	<date-setting lenient="false">
		<!-- DateString的格式設定 -->
		<date-string input-pattern="yyyyMMdd" persist-pattern="yyyyMMdd"
			display-pattern="yyyyMMdd" />
		<date-time-string input-pattern="yyyyMMdd HH:mm:ss"
			persist-pattern="yyyyMMdd HH:mm:ss" display-pattern="yyyyMMdd HH:mm:ss" />
		<time-pattern>HH:mm:ss</time-pattern>
		<full-pattern>yyyyMMdd HH:mm:ss</full-pattern>
	</date-setting>
	<!-- 設定Persistence transaction-class : PersistableTransaction的實作類別. 此外在<persistence/>內可利用<param/> 
		來設定transaciton-manager-factory的相關參數, 實際需設定之參數視各種不同之實作而訂. -->
	<persistence transaction-manager-factory="com.edstw.persist.impl.PersistableManagerFactoryImpl">
		<transactional-resources
			default-transactional-resource-name="LogSearchJdbcLdssDSResource">
			<transactional-resource name="LogSearchJdbcLdssDSResource"
				class="com.edstw.persist.jdbc.impl.DataSourceTransactionalResource">
				<param name="dataSourceName" value="LogSearchJdbcLdssDS" />
			</transactional-resource>
		</transactional-resources>
		<dao-manager>
			<!-- 設定DAO物件. name: dao名稱, 在程式中需使用此名稱透過DaoManager取得對應之DAO物件. class: dao類別. 
				transactional-resource-name: 指定此dao物件要使用之TransactionalResource的name. 若未設定, 
				則會使用預設之transactional resource name. -->
			<!-- <dao name="paramDao" class="proj.nccc.logsearch.dao.ParamDAO" transactional-resource-name="emsDSResource"/> -->
		</dao-manager>
		<!-- 設定StoreManager, 可設定多個 store-manager-class : PersistableManager的實作類別. 
			此外在<manager/>內可利用<param/> 來設定PersistableManager的相關參數, 實際需設定之參數視各種不同之PersistableManager之實作而訂. -->
		<store-manager store-manager-class="com.edstw.persist.jdbc.impl.JdbcStoreManagerImpl"
			transactional-resource-name="LogSearchJdbcLdssDSResource">
			<!-- 設定Persistable類別及其PersistableStore類別 class : Persistable類別 store : 
				PersistableStore類別 -->
			<!-- <persistable class="proj.nccc.logsearch.persist.Authorization"> <store 
				class="proj.nccc.logsearch.persist.AuthorizationStore"> <param name="generatedKeyProperty" 
				value="id"/> </store> </persistable> -->
			<persistable class="com.edstw.nccc.sql.log.AccessLog">
				<store class="com.edstw.nccc.sql.log.AccessLogStore">
					<param name="accessLogTableName" value="" />
				</store>
			</persistable>
						
			 <persistable class="proj.nccc.logsearch.persist.EmvCardType">
				<store class="proj.nccc.logsearch.persist.EmvCardTypeStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.EmvCardTypeTemp">
				<store class="proj.nccc.logsearch.persist.EmvCardTypeTempStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.EmvUiLog">
				<store class="proj.nccc.logsearch.persist.EmvUiLogStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.EmvRefSpec">
				<store class="proj.nccc.logsearch.persist.EmvRefSpecStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.EmvRefSpecTemp">
				<store class="proj.nccc.logsearch.persist.EmvRefSpecTempStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.EmvTagRecordMaster">
				<store class="proj.nccc.logsearch.persist.EmvTagRecordMasterStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.EmvTagRecordDetail">
				<store class="proj.nccc.logsearch.persist.EmvTagRecordDetailStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.EmvTagRecordMasterTemp">
				<store class="proj.nccc.logsearch.persist.EmvTagRecordMasterTempStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.EmvTagRecordDetailTemp">
				<store class="proj.nccc.logsearch.persist.EmvTagRecordDetailTempStore"/>
			</persistable> 
			
			<persistable class="proj.nccc.logsearch.persist.AuthAccessLog">
				<store class="proj.nccc.logsearch.persist.AuthAccessLogStore"/>
			</persistable> 
			
			<persistable class="proj.nccc.logsearch.persist.AuthLogData">
				<store class="proj.nccc.logsearch.persist.AuthLogDataStore"/>
			</persistable>
			
			<persistable class="proj.nccc.logsearch.persist.ChesgDailyTotals">
				<store class="proj.nccc.logsearch.persist.ChesgDailyTotalsStore"/>
			</persistable>
			
			<!-- aplog start -->	
			<persistable class="com.dxc.nccc.aplog.edstw.persist.LogMasterImpl">
				<store class="com.dxc.nccc.aplog.edstw.persist.LogMasterImplStore">
					<param name="tableName" value="LOG_MASTER"/>
				</store>
			</persistable>
			<persistable class="com.dxc.nccc.aplog.edstw.persist.LogDetailImpl">
				<store class="com.dxc.nccc.aplog.edstw.persist.LogDetailImplStore">
					<param name="tableName" value="LOG_DETAIL"/>
				</store>
			</persistable>				
			<persistable class="com.dxc.nccc.aplog.edstw.persist.LogFunctionState">
				<store class="com.dxc.nccc.aplog.edstw.persist.LogFunctionStateStore">
					<param name="tableName" value="LOG_FUNCTION_STATS"/>
				</store>
			</persistable>	
			<!-- aplog end -->
		</store-manager>
		<!-- <store-manager store-manager-class="com.edstw.persist.io.IOPersistableManager"> 
			<persistable class="com.edstw.web.struts.FormFilePersistable" store="com.edstw.web.struts.FormFilePersistableStore"/> 
			</store-manager> -->
	</persistence>
