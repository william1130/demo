		<param-value>/validator-rules.xml,/validation.xml</param-value>
	</context-param>
	<context-param>
		<param-name>validation-stop-on-error</param-name>
		<param-value>true</param-value>
	</context-param>
	<context-param>
		<param-name>aplog-file</param-name>
		<param-value>/WEB-INF/conf/aplog.xml</param-value>
	</context-param>
	<!-- To check whether system initialized correctly, WebAvailabilityFilter 
		must be declared before all other filters, or some other unexpected error 
		would occur. -->
	<filter>
		<filter-name>WebAvailabilityFilter</filter-name>
		<filter-class>com.edstw.web.filter.WebAvailabilityFilter</filter-class>
		<init-param>
			<param-name>error_page</param-name>
			<param-value>/jsp/not_available.jsp</param-value>
		</init-param>
	</filter>
	<filter>
		<filter-name>EncodingFilter</filter-name>
		<filter-class>com.edstw.web.filter.EncodingFilter</filter-class>
		<init-param>
			<param-name>encoding</param-name>
			<param-value>UTF-8</param-value>
		</init-param>
	</filter>
	<filter>
		<filter-name>LoginFilter</filter-name>
		<filter-class>com.edstw.web.filter.LoginFilter</filter-class>
		<init-param>
			<param-name>login_page</param-name>
			<param-value>/blank.jsp</param-value>
		</init-param>
		<init-param>
			<param-name>enable</param-name>
			<param-value>false</param-value>
		</init-param>
		<init-param>
			<param-name>ignore_pages</param-name>
			<param-value>/mfesUncloseStat.do /blank.jsp</param-value>
		</init-param>
	</filter>
	<filter>
		<filter-name>CurrentUserProfileFilter</filter-name>
		<filter-class>com.edstw.web.filter.CurrentUserProfileFilter</filter-class>
	</filter>
	<filter>
		<filter-name>AppDataSourceFilter</filter-name>
		<filter-class>com.edstw.sql.web.AppDataSourceFilter</filter-class>
	</filter>
	<filter>
		<filter-name>PersistableManagerFilter</filter-name>
		<filter-class>com.edstw.persist.web.PersistableManagerFilter</filter-class>
	</filter>
	<filter>
		<filter-name>ApLogManagerFilter</filter-name>
		<filter-class>com.dxc.nccc.aplog.edstw.ApLogManagerFilter</filter-class>
	</filter>
	<filter>
		<filter-name>Struts2Filter</filter-name>
		<filter-class>org.apache.struts2.dispatcher.filter.StrutsPrepareAndExecuteFilter</filter-class>
	</filter>
	<filter>
		<filter-name>OwaspFilter</filter-name>
		<filter-class>proj.nccc.logsearch.beans.OwaspFilter</filter-class>
		<init-param>
	        <param-name>enableHttpMethods</param-name>
	        <param-value>GET,POST</param-value>
    	</init-param>		
	</filter>
	<filter-mapping>
		<filter-name>WebAvailabilityFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>WebAvailabilityFilter</filter-name>
		<url-pattern>*.do</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>EncodingFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>EncodingFilter</filter-name>
		<url-pattern>*.do</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>LoginFilter</filter-name>
		<url-pattern>*.do</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>LoginFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>CurrentUserProfileFilter</filter-name>
		<url-pattern>*.do</url-pattern>
	</filter-mapping>
