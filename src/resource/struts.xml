<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 6.0//EN" "https://struts.apache.org/dtds/struts-6.0.dtd">

<struts>
	<!--
	<constant name="struts.enable.DynamicMethodInvocation" value="false" />
	<constant name="struts.convention.result.path" value="/WEB-INF" />
	-->
	<constant name="struts.enable.DynamicMethodInvocation" value="false" />
	<constant name="struts.devMode" value="false" />
	<constant name="struts.multipart.maxSize" value="50240000" />
	<constant name="struts.ui.theme" value="simple" />
	<!-- theme : simple, xhtml, css_xhtml, ajax -->
	<constant name="struts.custom.i18n.resources" value="web-message" />
	<constant name="struts.action.extension" value="do,ax,," />
	<constant name="struts.configuration.xml.reload" value="false" />
	<constant name="struts.i18n.reload" value="false" />
	<constant name="struts.i18n.encoding" value="UTF-8"/>
	<constant name="struts.ognl.allowStaticMethodAccess" value="true" />
	<package name="proj-default" namespace="/" extends="struts-default">
		<!-- <result-types>
            <result-type name="chainAction" class="com.edstw.struts2.result.ActionChainParamResult"/>
        </result-types> -->
		<interceptors>
			<interceptor name="userProfileInterceptor" class="com.edstw.struts2.interceptor.UserProfileInterceptor" />
			<interceptor name="actionLogInterceptor" class="com.edstw.struts2.interceptor.ActionLogInterceptor" />
			<!-- 若系統要使用Commons Validator, 要使用本interceptor -->
			<interceptor name="commonsValidatorInterceptor" class="com.edstw.struts2.commonsvalidator.CommonsValidatorInterceptor" />
			<!--
			因為要加入commonsValidatorInterceptor並插在workflow interceptor之前, 所以不能直接使用defaultStack, 若沒有使用commonsValidatorInterceptor, 則可直接使用此設定
			<interceptor-stack name="projStack">
				<interceptor-ref name="userProfileInterceptor" />
				<interceptor-ref name="actionLogInterceptor" />
				<interceptor-ref name="defaultStack" />
			</interceptor-stack>
			-->
			<!-- 此stack內容以default-stack為範本, 加入framework所需的interceptor, 主要是commonsValidatorInterceptor -->
			<interceptor-stack name="projStack">
				<interceptor-ref name="exception" />
				<interceptor-ref name="userProfileInterceptor" />
				<interceptor-ref name="actionLogInterceptor" />
				<interceptor-ref name="alias" />
				<interceptor-ref name="servletConfig" />
				<interceptor-ref name="i18n" />
				<interceptor-ref name="prepare" />
				<interceptor-ref name="chain" />
				<interceptor-ref name="scopedModelDriven" />
				<interceptor-ref name="modelDriven" />
				<interceptor-ref name="fileUpload" />
				<interceptor-ref name="checkbox" />
				<interceptor-ref name="datetime" />
				<interceptor-ref name="multiselect" />
				<interceptor-ref name="staticParams" />
				<interceptor-ref name="actionMappingParams" />
				<interceptor-ref name="params" />
				<interceptor-ref name="conversionError" />
				<interceptor-ref name="commonsValidatorInterceptor" />
				<interceptor-ref name="validation">
					<param name="excludeMethods">input,back,cancel,browse</param>
				</interceptor-ref>
				<interceptor-ref name="workflow">
					<param name="excludeMethods">input,back,cancel,browse</param>
				</interceptor-ref>
				<interceptor-ref name="debugging" />
			</interceptor-stack>
		</interceptors>
		<default-interceptor-ref name="projStack" />
		<default-action-ref name="index" />
		<global-results>
			<result name="error">/jsp/error_page.jsp</result>
		</global-results>
		<global-exception-mappings>
			<exception-mapping exception="java.lang.Exception" result="error" />
		</global-exception-mappings>
		<action name="index">
			<result>/index.jsp</result>
		</action>
	</package>
	<!-- Add packages here -->
	<include file="struts_ajax.xml" />
	<include file="struts_ae.xml" />
	<include file="struts_emv.xml" />
	<include file="struts_trans.xml" />
	<include file="struts_int.xml" />
	<include file="struts_auth.xml" />
	<include file="struts_report.xml" />
</struts>

