<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 6.0//EN" "https://struts.apache.org/dtds/struts-6.0.dtd">

<struts>
	<package name="report" namespace="/report" extends="proj-default">
		<action name="toQueryChesg">
			<result>/report/queryChesg.jsp</result>
		</action>
		<action name="queryChesg" method="queryChesg" class="proj.nccc.logsearch.struts.ReportActions">
			<result name="input">/report/queryChesg.jsp</result>
			<result name="Fail">/report/queryChesgList.jsp</result>
			<result name="Success">/report/queryChesgList.jsp</result>
		</action>
		<action name="queryChesgRpt" method="queryChesgRpt" class="proj.nccc.logsearch.struts.ReportActions">
			<result name="input">/report/queryChesg.jsp</result>
			<result name="Fail">/report/queryChesg.jsp</result>
		</action>
	</package>
</struts>

