<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ISO8583-config SYSTEM "iso8583.dtd">
<ISO8583-config encoding="BIG5" desc="SmartPay設定檔" type="BINARY">
	<header length="12" ref="default">SPI000000000</header>
	<parse id="default" desc="通用規格">
		<field num="3" type="NUMERIC" length="6" desc="Processing Code" />
		<field num="4" type="AMOUNT" desc="Amount, Transaction" />
		<field num="7" type="NUMERIC" length="10" desc="服務系統日期時間" />
		<field num="11" type="NUMERIC" length="6" desc="System Trace Audit Number" />
		<field num="12" type="TIME" desc="Time, Local Transaction" />
		<field num="13" type="DATE4" desc="Date, Local Transaction" />
		<field num="24" type="NUMERIC" length="3" desc="Network International Identifier" />
		<field num="25" type="NUMERIC" length="2" desc="POS Condition Code" />
		<field num="35" type="LLBIN" desc="卡片基本資料" ref="f35" />
		<field num="37" type="ALPHA" length="12" desc="Retrieval Reference Number" />
		<field num="39" type="ALPHA" length="2" desc="Response Code" />
		<field num="41" type="ALPHA" length="8" desc="Card Acceptor Terminal Identification" />
		<field num="42" type="ALPHA" length="15" desc="Card Acceptor Identification Code" />
		<field num="45" type="LLVAR" desc="促銷欄位" />
		<field num="55" type="SMARTPAYCHIP" desc="晶片卡交易資料" />
		<field num="58" type="SMARTPAYTAG" desc="Additional Data" />
		<field num="60" type="ALPHA" length="8" desc="端末設備查核碼" />
		<field num="61" type="LLLVAR" desc="收單行代號+收單處理單位代號" ref="f61" />
		<field num="62" type="LLLVAR" desc="訂單號碼" />
		<field num="63" type="LLLBIN" desc="原始交易資料" ref="f63" />
		<field num="64" type="BINARY" length="4" desc="MAC" />
	</parse>
	<parse id="f35" desc="卡片基本資料">
		<field num="1" type="ALPHA" length="8" desc="發卡單位代號(左靠右補0)" />
		<field num="2" type="ALPHA" length="16" desc="帳號" />
		<field num="3" type="BINARY" length="30" desc="備註欄" />
	</parse>
	<parse id="f61" desc="收單行代號+收單處理單位代號">
		<field num="1" type="ALPHA" length="3" desc="收單行代號" />
		<field num="2" type="ALPHA" length="4" desc="收單處理單位代號" />
	</parse>
	<parse id="f63" desc="原始交易資料">
		<field num="1" type="REDEF" desc="原始交易資料">
			<redefine default-ref="f63_reversal">
				<define selector-expression="vo.mti.mtic == T(com.hp.nccc.iso8583.common.ISO8583Context$MTIClass).Financial_Transaction and vo.mti.mtim == T(com.hp.nccc.iso8583.common.ISO8583Context$MTIMode).Issuer_Reconciliation_Request" ref="f63_confirm" />
				<define selector-expression="vo.getField(3).toString().equals('002120')" ref="f63_search" />
			</redefine>
		</field>
	</parse>
	<parse id="f63_reversal" desc="沖正交易原資料">
		<field num="1" type="ALPHA" length="8" desc="(原)端末設備查核碼" />
		<field num="2" type="ALPHA" length="8" desc="(原)端末設備代號" />
		<field num="3" type="NUMERIC" length="14" desc="(原)交易日期、時間" />
		<field num="4" type="ALPHA" length="12" desc="(原)RRN" />
	</parse>
	<parse id="f63_confirm" desc="confirm 原資料">
		<field num="1" type="NUMERIC" length="14" desc="(原)交易日期、時間" />
	</parse>
	<parse id="f63_search" desc="查詢 原資料">
		<field num="1" type="ALPHA" length="8" desc="(原)發卡單位代號" />
		<field num="2" type="ALPHA" length="16" desc="(原)帳號" />
	</parse>
	<chip dublebytestag="">
		<chip-field tag="10" length="1" desc="Transmission Date and Time (GMT)" />
		<chip-field tag="11" length="1" desc="Reason Code Description" />
	</chip>
</ISO8583-config>