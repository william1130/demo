<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ISO8583-config SYSTEM "iso8583.dtd">
<ISO8583-config encoding="BIG5" desc="ISO8583設定檔" type="BINARY">
	<header length="5" ref="default">TPDU</header>
	<parse id="default" desc="通用規格">
		<field num="2" type="LLVAR" desc="Primary Account Number" />
		<field num="3" type="BINARY" length="3" desc="Processing Code" />
		<field num="4" type="AMOUNT" desc="Amount, Transaction" />
		<field num="11" type="NUMERIC" length="6" desc="System Trace Audit Number" />
		<field num="12" type="TIME" desc="Time, Local Transaction" />
		<field num="13" type="DATE4" desc="Date, Local Transaction" />
		<field num="14" type="NUMERIC" length="4" desc="Date, Expired" />
		<field num="22" type="NUMERIC" length="4" desc="POS Entry Mode" />
		<field num="24" type="NUMERIC" length="4" desc="Network International Identifier" />
		<field num="25" type="NUMERIC" length="2" desc="POS Condition Code" />
		<field num="32" type="LLBIN" desc="Acquiring Institution Identification Code" />
		<field num="35" type="REDEF" desc="TRACK 2 Data" alt="s">
            <redefine default-ref="f35_default">
                <define selector-expression="vo.getField(3).toString().startsWith('254') || vo.getField(3).toString().startsWith('2525') || vo.getField(3).toString().startsWith('68')" ref="f35_smartpay" />
                <define selector-expression="vo.getField(3).toString().startsWith('51') || vo.getField(3).toString().startsWith('52') || vo.getField(3).toString().startsWith('53') || vo.getField(3).toString().startsWith('58')" ref="f35_et" />
                <define selector-expression="vo.getField(3).toString().substring(4,5).equals('A')" ref="f35_un" />
            </redefine>
        </field>
		<field num="37" type="ALPHA" length="12" desc="Retrieval Reference Number" />
		<field num="38" type="ALPHA" length="6" desc="Authorization Identification Response" />
		<field num="39" type="ALPHA" length="2" desc="Response Code" />
		<field num="41" type="ALPHA" length="8" desc="Card Acceptor Terminal Identification" />
		<field num="42" type="ALPHA" length="15" desc="Card Acceptor Identification Code" />
		<field num="48" type="LLLVAR" desc="Additional Data – Private Use" ref="f48"/>
		<field num="52" type="BINARY" length="8" desc="Pinblock Data" />
		<field num="54" type="LLLVAR" desc="Additional Amount" />
		<field num="55" type="LLLCHIP" desc="EMV Chip Data" />
		<!-- <field num="56" type="LLLCHIP" desc="EMV Related Data" /> -->
		<field num="56" type="LLLTABLES" desc="電子票證 Data" />
		<field num="57" type="LLLBIN" desc="T-SAM Decryption relation Data" />
		<field num="58" type="SMARTPAYTAG" desc="Smart Pay Relation Chip Data" alt="EDC"/>
		<field num="59" type="LLLTABLES" desc="Reserved – Private Data" />
		<field num="60" type="LLLBIN" desc="Reserved – Private Data" />
		<field num="61" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="62" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="63" type="LLLVAR" desc="Reserved – Private Data" ref="f63"/>
		<field num="64" type="BINARY" length="8" desc="Reserved – Private Data" />
	</parse>
	<parse id="f35_default" desc="TRACK 2 Data">
        <field num="1" type="LLZ" desc="Track 2 Data" alt="posfix:f" />
    </parse>
    <parse id="f35_et" desc="TRACK 2 Data">
        <field num="1" type="LLVAR" desc="Track 2 Data" />
    </parse>
    <parse id="f35_un" desc="TRACK 2 Data">
        <field num="1" type="LLVAR" desc="Track 2 Data" />
    </parse>
	<parse id="f35_smartpay" desc="卡片基本資料">
        <field num="1" type="LLBIN" desc="卡片基本資料" ref="f35_detail" />
    </parse>
	<parse id="f35_detail" desc="卡片基本資料">
        <field num="1" type="ALPHA" length="8" desc="發卡單位代號(左靠右補0)" />
        <field num="2" type="ALPHA" length="16" desc="帳號" />
        <field num="3" type="BINARY" length="30" desc="備註欄" />
    </parse>
    <parse id="f48" desc="Definition for NCCC for Transactions">
        <field num="1" type="BINARY" length="1" desc="SubField Length" />
        <field num="2" type="ALPHA" length="6" desc="Store ID" />
        <field num="3" type="ALPHA" length="6" desc="User Define" />
        <field num="4" type="ALPHA" length="6" desc="Other" />
    </parse>
    
   <parse id="f63" desc="Reserved-Private Data">
        <field num="1" type="REDEF" desc="Reserved-Private Data">
            <redefine default-ref="f63_default">
            	<define selector-expression="vo.getField(3).toString().equals('519200') || vo.getField(3).toString().equals('519600')" ref="f63_et" />
            </redefine>
        </field>
    </parse>

    <parse id="f63_default" desc="Batch Totals for Close Batch" >
		<field num="1" type="ALPHA" length="3" desc="Sale Count" />
		<field num="2" type="ALPHA" length="12" desc="Sale Amount" />
		<field num="3" type="ALPHA" length="3" desc="Refund Count" />
		<field num="4" type="ALPHA" length="12" desc="Refund Amount" />
		<field num="5" type="ALPHA" length="60" desc="Reserved" />
	</parse>

	<parse id="f63_et" desc="Batch Totals for Close Batch" >
		<field num="1" type="ALPHA" length="3" desc="購貨筆數_悠遊卡" />
		<field num="2" type="ALPHA" length="12" desc="購貨總額_悠遊卡" />
		<field num="3" type="ALPHA" length="3" desc="購貨取消筆數_悠遊卡" />
		<field num="4" type="ALPHA" length="12" desc="購貨取消總額_悠遊卡" />
		<field num="5" type="ALPHA" length="3" desc="現金加值筆數_悠遊卡" />
		<field num="6" type="ALPHA" length="12" desc="現金加值總額_悠遊卡" />
		<field num="7" type="ALPHA" length="3" desc="現金加值取消筆數_悠遊卡" />
		<field num="8" type="ALPHA" length="12" desc="現金加值取消總額_悠遊卡" />
		<field num="9" type="ALPHA" length="3" desc="自動加值筆數_悠遊卡" />
		<field num="10" type="ALPHA" length="12" desc="自動加值總額_悠遊卡" />
		<field num="11" type="ALPHA" length="3" desc="退貨筆數_悠遊卡" />
		<field num="12" type="ALPHA" length="12" desc="退貨總額_悠遊卡" />
		<field num="13" type="ALPHA" length="15" desc="Reserved_悠遊卡" />
		<field num="14" type="ALPHA" length="3" desc="購貨筆數_一卡通" />
		<field num="15" type="ALPHA" length="12" desc="購貨總額_一卡通" />
		<field num="16" type="ALPHA" length="3" desc="購貨取消筆數_一卡通" />
		<field num="17" type="ALPHA" length="12" desc="購貨取消總額_一卡通" />
		<field num="18" type="ALPHA" length="3" desc="現金加值筆數_一卡通" />
		<field num="19" type="ALPHA" length="12" desc="現金加值總額_一卡通" />
		<field num="20" type="ALPHA" length="3" desc="現金加值取消筆數_一卡通" />
		<field num="21" type="ALPHA" length="12" desc="現金加值取消總額_一卡通" />
		<field num="22" type="ALPHA" length="3" desc="自動加值筆數_一卡通" />
		<field num="23" type="ALPHA" length="12" desc="自動加值總額_一卡通" />
		<field num="24" type="ALPHA" length="3" desc="退貨筆數_一卡通" />
		<field num="25" type="ALPHA" length="12" desc="退貨總額_一卡通" />
		<field num="26" type="ALPHA" length="15" desc="Reserved_一卡通" />
		<field num="27" type="ALPHA" length="3" desc="購貨筆數_愛金卡" />
		<field num="28" type="ALPHA" length="12" desc="購貨總額_愛金卡" />
		<field num="29" type="ALPHA" length="3" desc="購貨取消筆數_愛金卡" />
		<field num="30" type="ALPHA" length="12" desc="購貨取消總額_愛金卡" />
		<field num="31" type="ALPHA" length="3" desc="現金加值筆數_愛金卡" />
		<field num="32" type="ALPHA" length="12" desc="現金加值總額_愛金卡" />
		<field num="33" type="ALPHA" length="3" desc="現金加值取消筆數_愛金卡" />
		<field num="34" type="ALPHA" length="12" desc="現金加值取消總額_愛金卡" />
		<field num="35" type="ALPHA" length="3" desc="自動加值筆數_愛金卡" />
		<field num="36" type="ALPHA" length="12" desc="自動加值總額_愛金卡" />
		<field num="37" type="ALPHA" length="3" desc="退貨筆數_愛金卡" />
		<field num="38" type="ALPHA" length="12" desc="退貨總額_愛金卡" />
		<field num="39" type="ALPHA" length="15" desc="Reserved_愛金卡" />
		<field num="40" type="ALPHA" length="3" desc="購貨筆數_遠鑫卡" />
		<field num="41" type="ALPHA" length="12" desc="購貨總額_遠鑫卡" />
		<field num="42" type="ALPHA" length="3" desc="購貨取消筆數_遠鑫卡" />
		<field num="43" type="ALPHA" length="12" desc="購貨取消總額_遠鑫卡" />
		<field num="44" type="ALPHA" length="3" desc="現金加值筆數_遠鑫卡" />
		<field num="45" type="ALPHA" length="12" desc="現金加值總額_遠鑫卡" />
		<field num="46" type="ALPHA" length="3" desc="現金加值取消筆數_遠鑫卡" />
		<field num="47" type="ALPHA" length="12" desc="現金加值取消總額_遠鑫卡" />
		<field num="48" type="ALPHA" length="3" desc="自動加值筆數_遠鑫卡" />
		<field num="49" type="ALPHA" length="12" desc="自動加值總額_遠鑫卡" />
		<field num="50" type="ALPHA" length="3" desc="退貨筆數_遠鑫卡" />
		<field num="51" type="ALPHA" length="12" desc="退貨總額_遠鑫卡" />
		<field num="52" type="ALPHA" length="15" desc="Reserved_遠鑫卡" />
	</parse>
	
	<table>
		<table-parse id="A" desc="Table ID A: TMS">
			<table-field num="1" type="ALPHA" length="8" desc="Host Date(TMS)" />
			<table-field num="2" type="ALPHA" length="6" desc="Host Time(TMS)" />
			<table-field num="3" type="ALPHA" length="1" desc="Download Flag" />
			<table-field num="4" type="ALPHA" length="1" desc="Download Scope" />
			<table-field num="5" type="ALPHA" length="15" desc="Download TEL" />
			<table-field num="6" type="ALPHA" length="8" desc="Schedule Date" />
			<table-field num="7" type="ALPHA" length="6" desc="Schedule Time" />
		</table-parse>
		<table-parse id="C" desc="Table ID 'C': CUP交易">
			<table-field num="1" type="ALPHA" length="1" desc="The terminal support CUP function" />
			<table-field num="2" type="ALPHA" length="1" desc="Terminal hot key control" />
			<table-field num="3" type="ALPHA" length="6" desc="CUP Trace Number(TN)" />
			<table-field num="4" type="ALPHA" length="4" desc="CUP Trancation Date(MMDD)" />
			<table-field num="5" type="ALPHA" length="6" desc="CUP Trancation Time(hhmmss)" />
			<table-field num="6" type="ALPHA" length="12" desc="CUP Retrieve Reference Number(CRRN)" />
			<table-field num="7" type="ALPHA" length="4" desc="Settlement date(MMDD)" />
		</table-parse>
		<table-parse id="D" desc="Table ID 'D': 經DCC詢價轉台幣交易">
			<table-field num="1" type="ALPHA" length="1" desc="DCC flag" />
		</table-parse>
		<table-parse id="O" desc="Table ID 'O': Pre-Auth Complete交易">
			<table-field num="1" type="ALPHA" length="4" desc="Original Transaction Date(MMDD)" />
			<table-field num="2" type="ALPHA" length="12" desc="Original Amount" />
		</table-parse>
		<table-parse id="S" desc="Table ID 'S': 持卡人自助交易">
			<table-field num="1" type="ALPHA" length="1" desc="Cardholder Present Indicator" />
			<table-field num="2" type="ALPHA" length="1" desc="Card Present Indicator" />
			<table-field num="3" type="ALPHA" length="1" desc="Transaction Status Indicator" />
			<table-field num="4" type="ALPHA" length="1" desc="Transaction Security Indicator" />
			<table-field num="5" type="ALPHA" length="1" desc="Cardholder Activated Terminal Indicator" />
			<table-field num="6" type="ALPHA" length="1" desc="Cardholder ID Method" />
			<table-field num="7" type="ALPHA" length="1" desc="Terminal Input Capability Indicator" />
		</table-parse>
		<table-parse id="Y" desc="Table ID 'Y': 取得主機的交易西元年">
			<table-field num="1" type="ALPHA" length="4" desc="YYYY" />
		</table-parse>
		<table-parse id="N1" desc="Table ID “N1”: CUP交易">
			<table-field num="1" type="ALPHA" length="1" desc="The terminal support CUP function" />
			<table-field num="2" type="ALPHA" length="1" desc="Terminal hot key control" />
			<table-field num="3" type="ALPHA" length="6" desc="CUP Trace Number(TN)" />
			<table-field num="4" type="ALPHA" length="4" desc="CUP Trancation Date(MMDD)" />
			<table-field num="5" type="ALPHA" length="6" desc="CUP Trancation Time(hhmmss)" />
			<table-field num="6" type="ALPHA" length="12" desc="CUP Retrieve Reference Number(CRRN)" />
			<table-field num="7" type="ALPHA" length="4" desc="Settlement date(MMDD)" />
		</table-parse>
		<table-parse id="N2" desc="Table ID “N2”: Settlement Flag">
			<table-field num="1" type="ALPHA" length="2" desc="依TMS下載的Settlement Flag填入此欄位" />
		</table-parse>
		<table-parse id="N3" desc="Table ID “N3”: Host AD “YYYY” (系統西元年)">
			<table-field num="1" type="ALPHA" length="4" desc="YYYY" />
		</table-parse>
		<table-parse id="N4" desc="Table ID “N4”: 分期資料">
			<table-field num="1" type="ALPHA" length="1" desc="Installment Indicator(分期標記)" />
			<table-field num="2" type="ALPHA" length="2" desc="Installment Period(期數)" />
			<table-field num="3" type="ALPHA" length="8" desc="Down Payment(首期金額)" />
			<table-field num="4" type="ALPHA" length="8" desc="Installment Payment(每期金額)" />
			<table-field num="5" type="ALPHA" length="6" desc="Formality Fee(手續費)" />
			<table-field num="6" type="ALPHA" length="2" desc="Response Code" />
		</table-parse>
		<table-parse id="N5" desc="Table ID “N5”: 紅利資料">
			<table-field num="1" type="ALPHA" length="1" desc="Online Redeem Indicator(紅利標記)" />
			<table-field num="2" type="ALPHA" length="8" desc="Point of Redemption(紅利扣抵點數)" />
			<table-field num="3" type="ALPHA" length="1" desc="Sign of Balance(剩餘點數之正負值)" />
			<table-field num="4" type="ALPHA" length="8" desc="Point of Balance(紅利剩餘點數)" />
			<table-field num="5" type="ALPHA" length="10" desc="Paid Credit Amount(紅利支付金額)" />
			<table-field num="6" type="ALPHA" length="2" desc="Response Code" />
		</table-parse>
		<table-parse id="N6" desc="Table ID “N6”: DCC Change to Pay NTD(DCC 轉台幣支付)">
			<table-field num="1" type="ALPHA" length="1" desc="DCC flag" />
		</table-parse>
		<table-parse id="N7" desc="Table ID “N7”: Preauth Complete Relation Data (預授權完成資料)">
			<table-field num="1" type="ALPHA" length="4" desc="Original Transaction Date(MMDD)" />
			<table-field num="2" type="ALPHA" length="12" desc="Original Amount" />
		</table-parse>
		<table-parse id="N8" desc="Table ID 'N8': AE card 4DBC">
			<table-field num="1" type="BINARY" length="4" desc="AE Card 4DBC值" />
		</table-parse>
		<table-parse id="N9" desc="Table ID “N9”: Mail/Telephone Order Relation Data">
			<table-field num="1" type="ALPHA" length="1" desc="MO/TO or EC flag" />
			<table-field num="2" type="ALPHA" length="1" desc="CVD Present (是否有上傳Table ID “N8”識別碼)" />
			<table-field num="3" type="ALPHA" length="1" desc="The authentication collection indicator valid" />
			<table-field num="4" type="ALPHA" length="1" desc="本欄位預設值為空白(0x20)" />
		</table-parse>
		<table-parse id="NA" desc="Table ID “NA”: Call Bank Referral Telephone no.">
			<table-field num="1" type="ALPHA" length="15" desc="含區號的電話號碼" />
		</table-parse>
		<table-parse id="NC" desc="Table ID “NC”: MCP Indicator / Issue Bank ID (行動支付標記及金融機構代碼)">
			<table-field num="1" type="LVAR" length="1" desc="MCP Indicator / Issue Bank ID" />
			<!-- <table-field num="1" type="ALPHA" length="1" desc="MCP(手機支付)" />
			<table-field num="2" type="ALPHA" length="3" desc="發卡行金融機構代碼" />
			<table-field num="3" type="ALPHA" length="1" desc="卡別簡碼" />
			<table-field num="4" type="ALPHA" length="2" desc="卡別名稱長度" /> -->
		</table-parse>
		<table-parse id="ND" desc="Table ID “ND”:FES ID (FES請款代碼 )">
			<table-field num="1" type="ALPHA" length="3" desc="FES ID" />
		</table-parse>
		<table-parse id="NE" desc="Table ID “NE”:電子簽單標記">
			<table-field num="1" type="ALPHA" length="1" desc="電子簽單標記：Y=本筆交易為電子簽單,N=本筆交易非電子簽單" />
		</table-parse>
		<table-parse id="NF" desc="Table ID “NF”: FES Indicator">
			<table-field num="1" type="ALPHA" length="4" desc="依TMS Config.txt中NCCC_FES_Mode參數設定上傳值" />
		</table-parse>
		<table-parse id="NI" desc="Table ID “NI”: E- Invoice vehicle Issue Bank ID">
			<table-field num="1" type="ALPHA" length="6" desc="支援電子發票載具之發卡行代碼" />
		</table-parse>
		<table-parse id="NP" desc="Table ID “NP”: Terminal Type (Only for miniPOS)">
			<table-field num="1" type="ALPHA" length="1" desc="miniPOS(手機刷卡機)專用，只有miniPOS需上傳此TableID" />
		</table-parse>
		<table-parse id="NQ" desc="Table ID “NQ”: ATS Quick Pay (快速支付免簽名) Flag">
			<table-field num="1" type="ALPHA" length="1" desc="ATS主機判斷免簽名邏輯" />
		</table-parse>
		<table-parse id="NS" desc="Table ID “NS”: Unattended Gas Station Relation Data(持卡人自助交易)">
			<table-field num="1" type="ALPHA" length="1" desc="Cardholder Present Indicator" />
			<table-field num="2" type="ALPHA" length="1" desc="Card Present Indicator" />
			<table-field num="3" type="ALPHA" length="1" desc="Transaction Status Indicator" />
			<table-field num="4" type="ALPHA" length="1" desc="Transaction Security Indicator" />
			<table-field num="5" type="ALPHA" length="1" desc="Cardholder Activated Terminal Indicator" />
			<table-field num="6" type="ALPHA" length="1" desc="Cardholder ID Method" />
			<table-field num="7" type="ALPHA" length="1" desc="Terminal Input Capability Indicator" />
		</table-parse>
		<table-parse id="NT" desc="Table ID “NT”: TMS 排程資訊">
			<table-field num="1" type="ALPHA" length="8" desc="Host Date(TMS)" />
			<table-field num="2" type="ALPHA" length="6" desc="Host Time(TMS)" />
			<table-field num="3" type="ALPHA" length="1" desc="Download Flag" />
			<table-field num="4" type="ALPHA" length="1" desc="Download Scope" />
			<table-field num="5" type="ALPHA" length="15" desc="Download TEL" />
			<table-field num="6" type="ALPHA" length="8" desc="Schedule Date" />
			<table-field num="7" type="ALPHA" length="6" desc="Schedule Time" />
		</table-parse>
		<table-parse id="NU" desc="Table ID “NU”: Pay Item code (繳費項目代碼)">
			<table-field num="1" type="ALPHA" length="5" desc="繳費項目代碼" />
		</table-parse>
		<table-parse id="NX" desc="Table ID“NX”:Card Number Header (MFES use only)">
            <table-field num="1" type="ALPHA" length="1" desc="MFES需上傳 EDC計算 MAC，卡號資料第一碼(SPDH規格)所填入之值" />
        </table-parse>
        <table-parse id="NY" desc="Table ID “NY”: 身分證字號/統一編號">
			<table-field num="1" type="LVAR" desc="ID Number/Company Tax ID (身分證字號/統一編號)" />
		</table-parse>
		<table-parse id="NZ" desc="Table ID “NZ”: 開卡密碼">
			<table-field num="1" type="BINARY" length="6" desc="Credit Card enable password(開卡密碼)" />
		</table-parse>
		<table-parse id="MP" desc="Table ID “MP”: MPAS Indicator (小額支付標記 )">
			<table-field num="1" type="ALPHA" length="1" desc="請求電文預設值 = ‘N’ (非小額支付) 若為小額支付由 ATS(MPAS) 改為回覆 ‘Y’。" />
		</table-parse>		
