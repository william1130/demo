<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ISO8583-config SYSTEM "iso8583.dtd">
<ISO8583-config encoding="BIG5" >
	<header length="5" ref="default">TPDU</header>
	<parse id="default" desc="通用規格">
		<field num="2" type="LLVAR" desc="Primary Account Number" />
		<field num="3" type="NUMERIC" length="6" desc="Processing Code" />
		<field num="4" type="AMOUNT" desc="Amount, Transaction" />
		<field num="11" type="NUMERIC" length="6"
			desc="System Trace Audit Number" />
		<field num="12" type="TIME" desc="Time, Local Transaction" />
		<field num="13" type="DATE4" desc="Date, Local Transaction" />
		<field num="14" type="NUMERIC" length="4" desc="Date, Expired" />
		<field num="22" type="NUMERIC" length="4" desc="POS Entry Mode" />
		<field num="24" type="NUMERIC" length="4"
			desc="Network International Identifier" />
		<field num="25" type="NUMERIC" length="2" desc="POS Condition Code" />
		<field num="32" type="LLZ" desc="Acquiring Institution Identification Code" alt="posfix:F" />
		<field num="35" type="LLZ" desc="Track 2 Data" alt="posfix:0"/>
		<field num="37" type="ALPHA" length="12" desc="Retrieval Reference Number" />
		<field num="38" type="ALPHA" length="6"
			desc="Authorization Identification Response" />
		<field num="39" type="ALPHA" length="2" desc="Response Code" />
		<field num="41" type="ALPHA" length="8"
			desc="Card Acceptor Terminal Identification" />
		<field num="42" type="ALPHA" length="15"
			desc="Card Acceptor Identification Code" />
		<field num="48" type="LLLVAR" desc="Additional Data – Private Use" />
		<field num="52" type="BINARY" length="8" desc="Pinblock Data" />
		<field num="54" type="LLLVAR" desc="Additional Amount" />
		<field num="55" type="LLLCHIP" desc="EMV Chip Data" />
		<field num="56" type="LLLCHIP" desc="EMV Related Data" />
		<field num="57" type="LLLVAR" desc="T-SAM Decryption relation Data" />
		<field num="58" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="59" type="LLLTABLES" desc="Reserved – Private Data" />
		<field num="60" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="61" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="62" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="63" type="LLLVAR" desc="Reserved – Private Data"
			ref="f63" />
		<field num="64" type="BINARY" length="8" desc="Reserved – Private Data" />
	</parse>
	<parse id="f63" desc="Batch Totals for Close Batch" mti="0500" >
		<field num="1" type="ALPHA" length="3" desc="Sale Count" />
		<field num="2" type="ALPHA" length="12" desc="Sale Amount" />
		<field num="3" type="ALPHA" length="3" desc="Refund Count" />
		<field num="4" type="ALPHA" length="12" desc="Refund Amount" />
		<field num="5" type="ALPHA" length="60" desc="Reserved" />
	</parse>
	<table>
		<table-parse id="C" desc="Table ID 'C': CUP交易">
			<table-field num="1" type="ALPHA" length="1"
				desc="The terminal support CUP function" />
			<table-field num="2" type="ALPHA" length="1"
				desc="Terminal hot key control" />
			<table-field num="3" type="ALPHA" length="6"
				desc="CUP Trace Number(TN)" />
			<table-field num="4" type="ALPHA" length="4"
				desc="CUP Trancation Date(MMDD)" />
			<table-field num="5" type="ALPHA" length="6"
				desc="CUP Trancation Time(hhmmss)" />
			<table-field num="6" type="ALPHA" length="12"
				desc="CUP Retrieve Reference Number(CRRN)" />
			<table-field num="7" type="ALPHA" length="4"
				desc="Settlement date(MMDD)" />
		</table-parse>
		<table-parse id="D" desc="Table ID 'D': 經DCC詢價轉台幣交易">
			<table-field num="1" type="ALPHA" length="1" desc="DCC flag" />
		</table-parse>
		<table-parse id="O" desc="Table ID 'O': Pre-Auth Complete交易">
			<table-field num="1" type="ALPHA" length="4"
				desc="Original Transaction Date(MMDD)" />
			<table-field num="2" type="ALPHA" length="12"
				desc="Original Amount" />
		</table-parse>
		<table-parse id="S" desc="Table ID 'S': 持卡人自助交易">
			<table-field num="1" type="ALPHA" length="1"
				desc="Cardholder Present Indicator" />
			<table-field num="2" type="ALPHA" length="1"
				desc="Card Present Indicator" />
			<table-field num="3" type="ALPHA" length="1"
				desc="Transaction Status Indicator" />
			<table-field num="4" type="ALPHA" length="1"
				desc="Transaction Security Indicator" />
			<table-field num="5" type="ALPHA" length="1"
				desc="Cardholder Activated Terminal Indicator" />
			<table-field num="6" type="ALPHA" length="1"
				desc="Cardholder ID Method" />
			<table-field num="7" type="ALPHA" length="1"
				desc="Terminal Input Capability Indicator" />
		</table-parse>
		<table-parse id="Y" desc="Table ID 'Y': 取得主機的交易西元年">
			<table-field num="1" type="ALPHA" length="4" desc="YYYY" />
		</table-parse>
		<table-parse id="N1" desc="Table ID “N1”: CUP交易">
			<table-field num="1" type="ALPHA" length="1"
				desc="The terminal support CUP function" />
			<table-field num="2" type="ALPHA" length="1"
				desc="Terminal hot key control" />
			<table-field num="3" type="ALPHA" length="6"
				desc="CUP Trace Number(TN)" />
			<table-field num="4" type="ALPHA" length="4"
				desc="CUP Trancation Date(MMDD)" />
			<table-field num="5" type="ALPHA" length="6"
				desc="CUP Trancation Time(hhmmss)" />
			<table-field num="6" type="ALPHA" length="12"
				desc="CUP Retrieve Reference Number(CRRN)" />
			<table-field num="7" type="ALPHA" length="4"
				desc="Settlement date(MMDD)" />
		</table-parse>
		<table-parse id="N2" desc="Table ID “N2”: Settlement Flag">
			<table-field num="1" type="ALPHA" length="2"
				desc="依TMS下載的Settlement Flag填入此欄位" />
		</table-parse>
		<table-parse id="N3" desc="Table ID “N3”: Host AD “YYYY” (系統西元年)">
			<table-field num="1" type="ALPHA" length="4" desc="YYYY" />
		</table-parse>
		<table-parse id="N4" desc="Table ID “N4”: 分期資料">
			<table-field num="1" type="ALPHA" length="1"
				desc="Installment Indicator(分期標記)" />
			<table-field num="2" type="ALPHA" length="2"
				desc="Installment Period(期數)" />
			<table-field num="3" type="ALPHA" length="8"
				desc="Down Payment(首期金額)" />
			<table-field num="4" type="ALPHA" length="8"
				desc="Installment Payment(每期金額)" />
			<table-field num="5" type="ALPHA" length="6"
				desc="Formality Fee(手續費)" />
			<table-field num="6" type="ALPHA" length="2" desc="Response Code" />
		</table-parse>
		<table-parse id="N5" desc="Table ID “N5”: 紅利資料">
			<table-field num="1" type="ALPHA" length="1"
				desc="Online Redeem Indicator(紅利標記)" />
			<table-field num="2" type="ALPHA" length="8"
				desc="Point of Redemption(紅利扣抵點數)" />
			<table-field num="3" type="ALPHA" length="1"
				desc="Sign of Balance(剩餘點數之正負值)" />
			<table-field num="4" type="ALPHA" length="8"
				desc="Point of Balance(紅利剩餘點數)" />
			<table-field num="5" type="ALPHA" length="10"
				desc="Paid Credit Amount(紅利支付金額)" />
			<table-field num="6" type="ALPHA" length="2" desc="Response Code" />
		</table-parse>
		<table-parse id="N6"
			desc="Table ID “N6”: DCC Change to Pay NTD(DCC 轉台幣支付)">
			<table-field num="1" type="ALPHA" length="1" desc="DCC flag" />
		</table-parse>
		<table-parse id="N7"
			desc="Table ID “N7”: Preauth Complete Relation Data (預授權完成資料)">
			<table-field num="1" type="ALPHA" length="4"
				desc="Original Transaction Date(MMDD)" />
			<table-field num="2" type="ALPHA" length="12"
				desc="Original Amount" />
		</table-parse>
		<table-parse id="N8" desc="Table ID 'N8': AE card 4DBC">
			<table-field num="1" type="ALPHA" length="4" desc="AE Card 4DBC值" />
		</table-parse>
		<table-parse id="N9"
			desc="Table ID “N9”: Mail/Telephone Order Relation Data">
			<table-field num="1" type="ALPHA" length="1"
				desc="MO/TO or EC flag" />
			<table-field num="2" type="ALPHA" length="1"
				desc="CVD Present (是否有上傳Table ID “N8”識別碼)" />
			<table-field num="3" type="ALPHA" length="1"
				desc="The authentication collection indicator valid" />
			<table-field num="4" type="ALPHA" length="1"
				desc="本欄位預設值為空白(0x20)" />
		</table-parse>
		<table-parse id="NA"
			desc="Table ID “NA”: Call Bank Referral Telephone no.">
			<table-field num="1" type="ALPHA" length="15" desc="含區號的電話號碼" />
		</table-parse>
		<table-parse id="NF" desc="Table ID “NF”: FES Indicator">
			<table-field num="1" type="ALPHA" length="4"
				desc="依TMS Config.txt中NCCC_FES_Mode參數設定上傳值" />
		</table-parse>
		<table-parse id="NI" desc="Table ID “NI”: ATS Stand In Approve Flag">
			<table-field num="1" type="ALPHA" length="1" desc="ATS代行授權旗標" />
		</table-parse>
		<table-parse id="NP"
			desc="Table ID “NP”: Terminal Type (Only for miniPOS)">
			<table-field num="1" type="ALPHA" length="1"
				desc="miniPOS(手機刷卡機)專用，只有miniPOS需上傳此TableID" />
		</table-parse>
		<table-parse id="NS"
			desc="Table ID “NS”: Unattended Gas Station Relation Data(持卡人自助交易)">
			<table-field num="1" type="ALPHA" length="1"
				desc="Cardholder Present Indicator" />
			<table-field num="2" type="ALPHA" length="1"
				desc="Card Present Indicator" />
			<table-field num="3" type="ALPHA" length="1"
				desc="Transaction Status Indicator" />
			<table-field num="4" type="ALPHA" length="1"
				desc="Transaction Security Indicator" />
			<table-field num="5" type="ALPHA" length="1"
				desc="Cardholder Activated Terminal Indicator" />
			<table-field num="6" type="ALPHA" length="1"
				desc="Cardholder ID Method" />
			<table-field num="7" type="ALPHA" length="1"
				desc="Terminal Input Capability Indicator" />
		</table-parse>
		<table-parse id="NT" desc="Table ID “NT”: TMS 排程資訊">
			<table-field num="1" type="ALPHA" length="8" desc="Host Date(TMS)" />
			<table-field num="2" type="ALPHA" length="6" desc="Host Time(TMS)" />
			<table-field num="3" type="ALPHA" length="1" desc="Download Flag" />
			<table-field num="4" type="ALPHA" length="1" desc="Download Scope" />
			<table-field num="5" type="ALPHA" length="15" desc="Download TEL" />
			<table-field num="6" type="ALPHA" length="8" desc="Schedule Date" />
			<table-field num="7" type="ALPHA" length="6" desc="Schedule Time" />
		</table-parse>
		<table-parse id="NY" desc="Table ID “NY”: 身分證字號">
			<table-field num="1" type="BINARY" length="10"
				desc="ID Number (身分證字號)" />
		</table-parse>
		<table-parse id="NZ" desc="Table ID “NZ”: 開卡密碼">
			<table-field num="1" type="BINARY" length="6"
				desc="Credit Card enable password(開卡密碼)" />
		</table-parse>
		<table-parse id="E1"
			desc="Table ID “E1”: Receipt Content Layout (簽單文字檔內容)">
			<table-field num="1" type="ALPHA" length="28"
				desc="簽單唯一序號(ESC S/N)" />
			<table-field num="2" type="ALPHA" length="10"
				desc="卡別簡碼2碼+卡號前4碼+卡號末4碼" />
			<table-field num="3" type="ALPHA" length="2"
				desc="簽單文字檔內容總封包數(Total Packet Counts)" />
			<table-field num="4" type="ALPHA" length="2"
				desc="目前傳送第幾個封包(Current Packet Count Number)" />
			<table-field num="5" type="ALPHA" length="5"
				desc="簽單文字檔內容完整封包長度(Receipt Content Total Length)" />
			<table-field num="6" type="ALPHA" length="3"
				desc="本封包內容長度(Current Packet Receipt Content Length)" />
			<table-field num="7" type="LBINARY" desc="簽單文字檔內容(壓縮及加密)" />
			<table-field num="8" type="CHECKSUM" length="1"
				desc="檢查碼(Checksum)" alt="7-8" />
		</table-parse>
		<table-parse id="E2"
			desc="Table ID “E2”: Electronic Signature File (電子簽名檔)">
			<table-field num="1" type="ALPHA" length="28"
				desc="簽單唯一序號(ESC S/N)" />
			<table-field num="2" type="ALPHA" length="10"
				desc="卡別簡碼2碼+卡號前4碼+卡號末4碼" />
			<table-field num="3" type="ALPHA" length="2"
				desc="電子簽名檔總封包數(Total Packet Counts)" />
			<table-field num="4" type="ALPHA" length="2"
				desc="目前傳送第幾個封包(Current Packet Count Number)" />
			<table-field num="5" type="ALPHA" length="5"
				desc="電子簽名完整檔案長度(ES File Total Length)" />
			<table-field num="6" type="ALPHA" length="3"
				desc="本封包電子簽名內容長度(Current Packet ES file Length)" />
			<table-field num="7" type="LBINARY" desc="電子簽名內容" />
			<table-field num="8" type="CHECKSUM" length="1"
				desc="檢查碼(Checksum)" alt="7-8" />
		</table-parse>
		<table-parse id="L1" desc="Table ID “L1”: Reward (優惠活動)">
			<table-field num="1" type="ALPHA" length="1" desc="列印優惠或廣告資訊之個數" />
			<table-field num="2" type="ALPHA" length="22"
				desc="優惠序號(Award S/N)" />
			<table-field num="3" type="ALPHA" length="1" desc="是否列印補充資訊" />
			<table-field num="4" type="ALPHA" length="2" desc="補充資訊實際長度" />
			<table-field num="5" type="ALPHA" length="1" desc="補充資訊內容列印位置" />
			<table-field num="6" type="CHINESE" length="60" desc="補充資訊內容" />
			<table-field num="7" type="CHECKSUM" length="305"
				desc="檢查碼(Checksum)" ref="L1_SUB" />
			<table-field num="8" type="CHECKSUM" length="305"
				desc="檢查碼(Checksum)" ref="L1_SUB" />
		</table-parse>
		<table-parse id="L1_SUB" desc="優惠活動">
			<table-field num="1" type="ALPHA" length="1" desc="是否列印優惠活動之標題" />
			<table-field num="2" type="ALPHA" length="2" desc="優惠活動之標題長度" />
			<table-field num="3" type="CHINESE" length="50" desc="優惠活動之標題內容" />
			<table-field num="4" type="ALPHA" length="1" desc="是否列印一維條碼(一)" />
			<table-field num="5" type="ALPHA" length="2" desc="一維條碼(一)長度" />
			<table-field num="6" type="ALPHA" length="20" desc="一維條碼(一)" />
			<table-field num="7" type="ALPHA" length="1" desc="是否列印一維條碼(二)" />
			<table-field num="8" type="ALPHA" length="2" desc="一維條碼(二)長度" />
			<table-field num="9" type="ALPHA" length="20" desc="一維條碼(二)" />
			<table-field num="10" type="ALPHA" length="1" desc="保留欄位" />
			<table-field num="11" type="ALPHA" length="1" desc="是否列印優惠活動之內容" />
			<table-field num="12" type="ALPHA" length="3" desc="優惠活動之內容長度" />
			<table-field num="13" type="CHINESE" length="200" desc="優惠活動之內容" />
		</table-parse>
		<table-parse id="L2"
			desc="Table ID “L2”: Reward or Advertisement (優惠活動||累計訊息)及廣告資訊">
			<table-field num="1" type="ALPHA" length="1"
				desc="列印(優惠活動||累計訊息)及廣告資訊之個數" />
			<table-field num="2" type="ALPHA" length="22"
				desc="優惠序號(Award S/N)" />
			<table-field num="3" type="ALPHA" length="1" desc="是否列印補充資訊" />
			<table-field num="4" type="ALPHA" length="2" desc="補充資訊實際長度" />
			<table-field num="5" type="ALPHA" length="1" desc="補充資訊內容列印位置" />
			<table-field num="6" type="CHINESE" length="60" desc="補充資訊內容" />
			<table-field num="7" type="CHECKSUM" length="305"
				desc="檢查碼(Checksum)" ref="L1_SUB" />
			<table-field num="8" type="CHECKSUM" length="312"
				desc="檢查碼(Checksum)" ref="L2_SUB" />
		</table-parse>
		<table-parse id="L2_SUB" desc="廣告資訊">
			<table-field num="1" type="ALPHA" length="1"
				desc="是否列印(優惠活動||累計訊息)之標題" />
			<table-field num="2" type="ALPHA" length="2" desc="廣告資訊之標題長度" />
			<table-field num="3" type="CHINESE" length="50" desc="廣告資訊之標題內容" />
			<table-field num="4" type="ALPHA" length="1" desc="是否列印廣告資訊" />
			<table-field num="5" type="ALPHA" length="3" desc="廣告資訊長度" />
			<table-field num="6" type="CHINESE" length="150" desc="廣告資訊之內容" />
			<table-field num="7" type="ALPHA" length="1"
				desc="是否列印URL資訊之QR Code" />
			<table-field num="8" type="ALPHA" length="3" desc="URL資訊長度" />
			<table-field num="9" type="CHINESE" length="100" desc="URL資訊之內容" />
		</table-parse>
		<table-parse id="L3"
			desc="Table ID “L3”: Redeem Information(優惠兌換資訊)">
			<table-field num="1" type="ALPHA" length="1" desc="兌換方式" />
			<table-field num="2" type="ALPHA" length="22"
				desc="優惠序號(Award S/N)" />
			<table-field num="3" type="ALPHA" length="1" desc="是否列印補充資訊" />
			<table-field num="4" type="ALPHA" length="2" desc="補充資訊實際長度" />
			<table-field num="5" type="CHINESE" length="20" desc="補充資訊內容" />
			<table-field num="6" type="ALPHA" length="1" desc="是否上傳一維條碼(一)" />
			<table-field num="7" type="ALPHA" length="2" desc="一維條碼(一)長度" />
			<table-field num="8" type="ALPHA" length="20" desc="一維條碼(一)" />
			<table-field num="9" type="ALPHA" length="1" desc="是否上傳一維條碼(二)" />
			<table-field num="10" type="ALPHA" length="2" desc="一維條碼(二)長度" />
			<table-field num="11" type="ALPHA" length="20" desc="一維條碼(二)" />
			<table-field num="12" type="ALPHA" length="1" desc="是否列印兌換核銷資訊(一)" />
			<table-field num="13" type="ALPHA" length="3" desc="兌換核銷資訊(一)長度" />
			<table-field num="14" type="CHINESE" length="100"
				desc="兌換核銷資訊(一)之內容" />
			<table-field num="15" type="ALPHA" length="1" desc="是否列印兌換核銷資訊(二)" />
			<table-field num="16" type="ALPHA" length="3" desc="兌換核銷資訊(二)長度" />
			<table-field num="17" type="CHINESE" length="100"
				desc="兌換核銷資訊(二)之內容" />
			<table-field num="18" type="CHECKSUM" length="1"
				desc="檢查碼(Checksum)" alt="1-17" />
		</table-parse>
		<table-parse id="L4" desc=" Table ID “L4”: Advice Information(通知資訊)">
			<table-field num="1" type="ALPHA" length="1" desc="通知內容" />
			<table-field num="2" type="ALPHA" length="1" desc="交易種類" />
		</table-parse>
	</table>

	<chip dublebytestag="5F,9F,DF">
		<chip-field tag="57" length="1" desc="Track 2 Equivalent Data" />
		<chip-field tag="5A" length="1" desc="Application PAN" />
		<chip-field tag="5F24" length="1" desc="Application Expiration Date" />
		<chip-field tag="5F2A" length="1" desc="Transaction Currency Code" />
		<chip-field tag="5F34" length="1"
			desc="Application PAN Sequence Number" />
		<chip-field tag="71" length="1" desc="Issuer Script Template 1" />
		<chip-field tag="72" length="1" desc="Issuer Script Template 2" />
		<chip-field tag="82" length="1"
			desc="Application Interchange Profile" />
		<chip-field tag="84" length="1" desc="Dedicated file name" />
