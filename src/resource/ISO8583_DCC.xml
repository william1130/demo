<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ISO8583-config SYSTEM "iso8583.dtd">
<ISO8583-config encoding="BIG5" desc="DCC設定檔" type="BINARY">
	<header length="5" ref="default">TPDU</header>
	<parse id="default" desc="通用規格">
		<field num="2" type="LLVAR" desc="Primary Account Number" />
		<field num="3" type="NUMERIC" length="6" desc="Processing Code" />
		<field num="4" type="AMOUNT" desc="Amount, Transaction" />
		<field num="11" type="NUMERIC" length="6" desc="System Trace Audit Number" />
		<field num="12" type="TIME" desc="Time, Local Transaction" />
		<field num="13" type="DATE4" desc="Date, Local Transaction" />
		<field num="14" type="NUMERIC" length="4" desc="Date, Expired" />
		<field num="22" type="NUMERIC" length="4" desc="POS Entry Mode" />
		<field num="24" type="NUMERIC" length="4" desc="Network International Identifier" />
		<field num="25" type="NUMERIC" length="2" desc="POS Condition Code" />
		<!--<field num="32" type="ALPHA" length="5" desc="Acquiring Institution Identification Code" />-->
		<field num="35" type="LLZ" desc="Track 2 Data" />
        <!--<field num="35" type="REDEF" desc="TRACK 2 Data" alt="s">
            <redefine default-ref="f35_default">
                <define selector-expression="vo.getField(3).toString().startsWith('002000') || vo.getField(3).toString().startsWith('041000') || vo.getField(3).toString().startsWith('116000')" ref="f35_smartpay_pan" />
            </redefine>
        </field>-->		
		<field num="37" type="ALPHA" length="12" desc="Retrieval Reference Number" />
		<field num="38" type="ALPHA" length="6" desc="Authorization Identification Response" />
		<field num="39" type="ALPHA" length="2" desc="Response Code" />
		<field num="41" type="ALPHA" length="8" desc="Card Acceptor Terminal Identification" />
		<field num="42" type="ALPHA" length="15" desc="Card Acceptor Identification Code" />
		<field num="48" type="LLLVAR" desc="Additional Data – Private Use" />
		<field num="52" type="BINARY" length="8" desc="Pinblock Data" />
		<field num="54" type="LLLVAR" desc="Additional Amount" />
		<field num="55" type="LLLCHIP" desc="EMV Chip Data" />
		<field num="56" type="LLLCHIP" desc="EMV Related Data" />
		<field num="57" type="LLLBIN" desc="T-SAM Decryption relation Data" />
		<field num="58" type="LLLTABLES" desc="Reserved – Private Data" />
		<field num="59" type="LLLTABLES" desc="Reserved – Private Data" />
		<field num="60" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="61" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="62" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="63" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="64" type="BINARY" length="8" desc="Reserved – Private Data" />
	</parse>
     
	<table>
		<table-parse id="A" desc="TMS related data" length-type="2-H">
			<table-field num="1" type="ALPHA" length="8"
				desc="Host Date(TMS)" />
			<table-field num="2" type="ALPHA" length="6"
				desc="Host Time(TMS)" />
			<table-field num="3" type="ALPHA" length="1"
				desc="Download Flag" />
			<table-field num="4" type="ALPHA" length="1"
				desc="Download Scope" />
			<table-field num="5" type="ALPHA" length="15"
				desc="Download TEL" />
			<table-field num="6" type="ALPHA" length="8"
				desc="Schedule Date" />
			<table-field num="7" type="ALPHA" length="6"
				desc="Schedule Time" />
		</table-parse>
		<table-parse id="D" desc="Table ID 'D': DCC transaction information" length-type="2-H">
			<table-field num="1" type="ALPHA" length="3" desc="Foreign Currency Number" />
			<table-field num="2" type="ALPHA" length="12" desc="Foreign Currency Amount" />
			<table-field num="3" type="ALPHA" length="1" desc="Foreign Currency Minor Unit" />
		</table-parse>
		<table-parse id="O" desc="Table ID 'O': Pre-Auth Complete交易" length-type="2-H">
			<table-field num="1" type="ALPHA" length="4"
				desc="Original Transaction Date(MMDD)" />
			<table-field num="2" type="ALPHA" length="12"
				desc="Original Amount" />
		</table-parse>
		<table-parse id="E" desc="Table ID 'E': DCC Exchange Rate information" length-type="2-H">
			<table-field num="1" type="ALPHA" length="1"
				desc="Exchange Rate Minor Unit" />
			<table-field num="2" type="ALPHA" length="9"
				desc="Exchange Rate Value" />
		</table-parse>
		<table-parse id="R" desc="Table ID 'R': DCC Rate Request information" length-type="2-H">
			<table-field num="1" type="ALPHA" length="3" desc="Foreign Currency No. For Rate" />
			<table-field num="2" type="ALPHA" length="4" desc="Action Code" />
			<table-field num="3" type="ALPHA" length="3" desc="Foreign Currency Number" />
			<table-field num="4" type="ALPHA" length="12" desc="Foreign Currency Amount" />
			<table-field num="5" type="ALPHA" length="1" desc="Foreign Currency Minor Unit" />
			<table-field num="6" type="ALPHA" length="3" desc="Foreign Currency Alphabetic Code" />
			<table-field num="7" type="ALPHA" length="1" desc="Exchange Rate Minor Unit" />
			<table-field num="8" type="ALPHA" length="9" desc="Exchange Rate Value " />
			<table-field num="9" type="ALPHA" length="1" desc="Inverted Rate Minor Unit" />
			<table-field num="10" type="ALPHA" length="9" desc="Inverted Rate Value" />
			<table-field num="11" type="ALPHA" length="1" desc="Inverted Rate Display Unit" />
			<table-field num="12" type="ALPHA" length="8" desc="Markup Percentage Value" />
			<table-field num="13" type="ALPHA" length="1" desc="Markup Percentage Decimal Point" />
			<table-field num="14" type="ALPHA" length="3" desc="Commission Value Currency Number" />
			<table-field num="15" type="ALPHA" length="12" desc="Commission Value Currency Amount" />
			<table-field num="16" type="ALPHA" length="1" desc="Commission Value Currency Minor Unit" />
			<table-field num="17" type="ALPHA" length="14" desc="Update Call Date and Time" />
		</table-parse>
		<table-parse id="F" desc="Table ID “F”: DCC information for Refund" length-type="2-H">
			<table-field num="1" type="ALPHA" length="4"
				desc="Original transaction date and time(MMDD)" />
			<table-field num="2" type="ALPHA" length="12"
				desc="Original transaction amount" />
			<table-field num="3" type="ALPHA" length="3"
				desc="Foreign Currency Number" />
			<table-field num="4" type="ALPHA" length="12"
				desc="Foreign Currency Amount" />
			<table-field num="5" type="ALPHA" length="1"
				desc="Foreign Currency Minor Unit" />
			<table-field num="6" type="ALPHA" length="3"
				desc="Foreign Currency Alphabetic Code" />
			<table-field num="7" type="ALPHA" length="1"
				desc="Inverted Rate Minor Unit" />
			<table-field num="8" type="ALPHA" length="9"
				desc="Inverted Rate Value" />
			<table-field num="9" type="ALPHA" length="1"
				desc="Inverted Rate Display Unit" />
			<table-field num="10" type="ALPHA" length="8"
				desc="Markup Percentage Value" />
			<table-field num="11" type="ALPHA" length="1"
				desc="Markup Percentage Decimal Point" />
			<table-field num="12" type="ALPHA" length="3"
				desc="Commission Value Currency Number" />
			<table-field num="13" type="ALPHA" length="12"
				desc="Commission Value Currency Amount" />
			<table-field num="14" type="ALPHA" length="1"
				desc="Commission Value Currency Minor Unit" />
		</table-parse>
		<table-parse id="G" desc="Table ID “G”: DCC Parameter Update Presentation information" length-type="2-H">
			<table-field num="1" type="ALPHA" length="1"
				desc="Installation Indicator" />
			<table-field num="2" type="ALPHA" length="4"
				desc="BIN Table Version" />
			<table-field num="3" type="ALPHA" length="8"
				desc="Batch/File transfer message count" />
			<table-field num="4" type="ALPHA" length="32"
				desc="Batch/File transfer file identification" />
			<table-field num="5" type="ALPHA" length="6"
				desc="File Transfer file size" />
			<table-field num="6" type="ALPHA" length="6"
				desc="File transfer elementary data record count" />
			<table-field num="7" type="ALPHA" length="6"
				desc="File transfer remaining elementary data record count" />
			<table-field num="8" type="BINARY" length="8"
				desc="Available Parameters" />
		</table-parse>
		<table-parse id="H" desc="DCC Parameter Update and BIN Update information" length-type="3-H">
			<table-field num="1" type="ALPHA" length="3" desc="Function Code" />
			<table-field num="2" type="ALPHA" length="8" desc="Batch/File transfer message count" />
			<table-field num="3" type="ALPHA" length="32" desc="Batch/File transfer file identification" />
			<table-field num="4" type="ALPHA" length="6" desc="File Transfer file size" />
			<table-field num="5" type="ALPHA" length="6" desc="File transfer elementary data record count" />
			<table-field num="6" type="ALPHA" length="6" desc="File transfer remaining elementary data record count" />
			<table-field num="7" type="ALPHA" length="4" desc="Action Code" />
			<table-field num="8" type="LLLBIN" desc="Data Record" />
		</table-parse>
		<table-parse id="I" desc="Table ID “I”: DCC Parameter Update Close information">
			<table-field num="1" type="ALPHA" length="4"
				desc="Action Cod" />
			<table-field num="2" type="ALPHA" length="1"
				desc="Parameter Update Result Code" />
			<table-field num="3" type="ALPHA" length="1"
				desc="BIN Table Update Result Code" />
		</table-parse>
		<table-parse id="Y" desc="Table ID “Y”: Year From authorization host">
			<table-field num="1" type="ALPHA" length="4"
				desc="Year(YYYY), From authorization host" />
		</table-parse>
		<table-parse id="X" desc="Table ID “X”: DCC Inquire All Exchange Rates" length-type="2-H">
			<!-- <table-field num="1" type="ALPHA" length="220" desc="DCC All Exchange Rate Data" /> -->
			<table-field num="1" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="2" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="3" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="4" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="5" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="6" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="7" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="8" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="9" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="10" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="11" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="12" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="13" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="14" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="15" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="16" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="17" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="18" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="19" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="20" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="21" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="22" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="23" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="24" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="25" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="26" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="27" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="28" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="29" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="30" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="31" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="32" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="33" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="34" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="35" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="36" type="ALPHA" length="8" desc="Invert Rate" />
			<table-field num="37" type="ALPHA" length="3" desc="Alphabetic ISO Currency Code" />
			<table-field num="38" type="ALPHA" length="3" desc="Numeric ISO Currency Code" />
			<table-field num="39" type="ALPHA" length="8" desc="Exchange Rate" />
			<table-field num="40" type="ALPHA" length="8" desc="Invert Rate" />
		</table-parse>
		<table-parse id="NC" desc="Table ID “NC”: MCP Indicator / Issue Bank ID (行動支付標記及金融機構代碼)">
			<table-field num="1" type="LVAR" length="1" desc="MCP Indicator / Issue Bank ID" />
		</table-parse>
		<table-parse id="ND" desc="Table ID “ND”:FES ID (FES請款代碼 )">
			<table-field num="1" type="ALPHA" length="3" desc="FES ID" />
		</table-parse>
		<table-parse id="NE" desc="Table ID “NE”:電子簽單標記">
			<table-field num="1" type="ALPHA" length="1" desc="電子簽單標記：Y=本筆交易為電子簽單,N=本筆交易非電子簽單" />
		</table-parse>
		<table-parse id="NF" desc="Table ID “NF”: FES Indicator">
			<table-field num="1" type="ALPHA" length="4" desc="依TMS Config.txt中NCCC_FES_Mode參數設定上傳值" />
		</table-parse>
		<table-parse id="U" desc="Table ID “U”: DCC flow information">
			<table-field num="1" type="ALPHA" length="2"
				desc="DCC flow information" />
		</table-parse>
	</table>

	<chip dublebytestag="5F,9F,DF">
		<chip-field tag="57" length="1" desc="Track 2 Equivalent Data" />
		<chip-field tag="5A" length="1" desc="Application PAN" />
		<chip-field tag="5F24" length="1" desc="Application Expiration Date" />
		<chip-field tag="5F2A" length="1" desc="Transaction Currency Code" />
		<chip-field tag="5F34" length="1" desc="Application PAN Sequence Number" />
		<chip-field tag="71" length="1" desc="Issuer Script Template 1" />
		<chip-field tag="72" length="1" desc="Issuer Script Template 2" />
		<chip-field tag="82" length="1" desc="Application Interchange Profile" />
		<chip-field tag="84" length="1" desc="Dedicated file name" />
		<chip-field tag="8A" length="1" desc="Authorization Response Code" />
		<chip-field tag="91" length="1" desc="Issuer Authentication Data" />
		<chip-field tag="95" length="1" desc="Terminal Verification Results (TVR)" />
		<chip-field tag="9A" length="1" desc="Transaction Date" />
		<chip-field tag="9B" length="1" desc="Transaction Status Information" />
		<chip-field tag="9C" length="1" desc="Transaction Type" />
		<chip-field tag="9F02" length="1" desc="Amount, Authorized" />
		<chip-field tag="9F03" length="1" desc="Amount, Other" />
		<chip-field tag="9F08" length="1" desc="Application version number in ICC" />
		<chip-field tag="9F09" length="1" desc="Application version number in terminal" />
		<chip-field tag="9F10" length="1" desc="Issuer Application Data (IAD)" />
		<chip-field tag="9F1A" length="1" desc="Terminal Country Code" />
		<chip-field tag="9F1E" length="1" desc="Interface Device (IFD) Serial Number" />
		<chip-field tag="9F26" length="1" desc="Application Cryptogram" />
		<chip-field tag="9F27" length="1" desc="Cryptogram Information Data" />
		<chip-field tag="9F33" length="1" desc="Terminal Capability Profile" />
		<chip-field tag="9F34" length="1" desc="Cardholder Verification Method Results" />
		<chip-field tag="9F35" length="1" desc="Terminal Type" />
		<chip-field tag="9F36" length="1" desc="Application Transaction Counter" />
		<chip-field tag="9F37" length="1" desc="Unpredictable Number" />
		<chip-field tag="9F41" length="1" desc="Transaction sequence counter" />
		<chip-field tag="9F5B" length="1" desc="Issuer Script Results" />
		<chip-field tag="9F61" length="1" desc="Form Factor Indicator" />
		<chip-field tag="9F63" length="1" desc="Card Product Label Information" />
		<chip-field tag="9F6E" length="1" desc="Form Factor Indicator/Third Party Data" />
		<chip-field tag="DFED" length="1" desc="Chip Condition Code" />
		<chip-field tag="DFEE" length="1" desc="Terminal Entry Capability" />
		<chip-field tag="DFEF" length="1" desc="Reason Online Code" />
		<chip-field tag="5331" length="1" desc="Smart Pay serial number" />
        <chip-field tag="5332" length="1" desc="Smart Pay TAC" />
        <chip-field tag="5333" length="1" desc="MCC/BranchBank ID" />
        <chip-field tag="5334" length="1" desc="Terminal Check Code" />
        <chip-field tag="5335" length="1" desc="Smart Pay RRN" />
        <chip-field tag="5336" length="1" desc="Original Transaction Date" />
        <chip-field tag="5337" length="1" desc="Transaction Date and Time" />
        <chip-field tag="9F60" length="1" desc="Coupon Information" />
	</chip>
</ISO8583-config>