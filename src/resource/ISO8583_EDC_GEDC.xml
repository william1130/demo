<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ISO8583-config SYSTEM "iso8583.dtd">
<ISO8583-config encoding="BIG5" desc="ISO8583 AE GEDC設定檔" type="BINARY">
	<header length="5" ref="default">TPDU</header>
	<parse id="default" desc="通用規格">
		<field num="2" type="LLZ" desc="PAN" alt="posfix:f" />
		<field num="3" type="NUMERIC" length="6" desc="Processing Code" />
		<field num="4" type="AMOUNT" desc="Amount, Transaction" />
		<field num="7" type="NUMERIC" desc="Date And Time, Transmission" />
		<field num="11" type="NUMERIC" length="6" desc="System Trace Audit Number" />
		<field num="12" type="TIME" desc="Time, Local Transaction" />
		<field num="13" type="DATE4" desc="Date, Local Transaction" />
		<field num="14" type="NUMERIC" length="4" desc="Date, Expired" />
		<field num="15" type="DATE4" desc="Date, Local Transaction2" />
		<field num="22" type="NUMERIC" length="4" desc="POS Entry Mode" />
		<field num="24" type="NUMERIC" length="4" desc="Network International Identifier" />
		<field num="25" type="NUMERIC" length="2" desc="POS Condition Code" />
		<field num="32" type="LLBIN" desc="Acquiring Institution Identification Code" />
		<field num="35" type="LLZ" desc="Track 2 Data" alt="posfix:f" />
		<field num="37" type="ALPHA" length="12" desc="Retrieval Reference Number" />
		<field num="38" type="ALPHA" length="6" desc="Authorization Identification Response" />
		<field num="39" type="ALPHA" length="2" desc="Response Code" />
		<field num="41" type="ALPHA" length="8" desc="Card Acceptor Terminal Identification" />
		<field num="42" type="ALPHA" length="15" desc="Card Acceptor Identification Code" />
		<field num="43" type="ALPHA" length="40" desc="Card Acceptor Name/Location" />
		<field num="44" type="LLVAR" desc="Additional Data – Resp data" />
		<field num="45" type="LLVAR" desc="Track 1" />
		<field num="47" type="LLLVAR" desc="Additional Data - National" />
		<field num="48" type="LLLVAR" desc="Additional Data – Private Use" />
		<field num="49" type="LLLVAR" desc="CurrencyCode, Transaction" />
		<field num="52" type="BINARY" length="8" desc="Pinblock Data" />
		<field num="54" type="LLLVAR" desc="Additional Amount" />
		<field num="55" type="LLLBIN" desc="ISO USE DATA" ref="f55" />
		<field num="59" type="LLLVAR" desc="National Use Data" />
		<field num="60" type="LLLVAR" desc="Reserved – Private Data" ref="f60" /> 
		<field num="61" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="62" type="LLLVAR" desc="Reserved – Private Data" />
		<field num="63" type="LLLVAR" desc="Reserved – Private Data"  />
		<field num="64" type="BINARY" length="8" desc="Reserved – Private Data" />
	</parse>
	
	<parse id="f55" desc="ISO USE DATA">
        <field num="1" type="REDEF">
            <redefine default-ref="f55_reuqest">
            	<define selector-expression="buf.length == 4" ref="f55_4dbc" />
            	<define selector-expression="vo.getMti().toString().endsWith('10') || vo.getMti().toString().endsWith('30')" ref="f55_response" />
            </redefine>
        </field>
    </parse>
	
	<parse id="f55_4dbc">
		<field num="1" type="ALPHA" length="4" desc="Card Identifier (CID)" />
	</parse>
	
	<parse id="f55_reuqest">
		<field num="1" type="EBCDIC" length="4" desc="Version Header" />
		<field num="2" type="BINARY" length="2" desc="Version Number" />
		<field num="3" type="BINARY" length="8" desc="9F26" />
		<field num="4" type="LLBINHEX" desc="9F10" />
		<field num="5" type="BINARY" length="4" desc="9F37" />
		<field num="6" type="BINARY" length="2" desc="9F36" />
		<field num="7" type="BINARY" length="5" desc="95" />
		<field num="8" type="BINARY" length="3" desc="9A" />
		<field num="9" type="BINARY" length="1" desc="9C" />
		<field num="10" type="BINARY" length="6" desc="9F02" />
		<field num="11" type="BINARY" length="2" desc="5F2A" />
		<field num="12" type="BINARY" length="2" desc="9F1A" />
		<field num="13" type="BINARY" length="2" desc="82" />
		<field num="14" type="BINARY" length="6" desc="9F03" />
		<field num="15" type="BINARY" length="1" desc="5F34" />
		<field num="16" type="BINARY" length="1" desc="9F27" />
		<field num="17" type="LLBINHEX" desc="9F06" />
		<field num="18" type="BINARY" length="2" desc="9F09" />
		<field num="19" type="BINARY" length="3" desc="9F34" />
		<field num="20" type="BINARY" length="5" desc="9F0E" />
		<field num="21" type="BINARY" length="5" desc="9F0F" />
		<field num="22" type="BINARY" length="5" desc="9F0D" />
		<field num="23" type="LLBINHEX" desc="Reserved for future use" />
	</parse>
	
	<parse id="f55_response">
		<field num="1" type="EBCDIC" length="4" desc="Version Header" />
		<field num="2" type="BINARY" length="2" desc="Version Number" />
		<field num="3" type="LLBINHEX" desc="91" />
		<field num="4" type="LLBINHEX" desc="Issuer Script Data" />
		<field num="5" type="LLBINHEX" desc="Reserved for future use" />
	</parse>
	
	<parse id="f60" desc="Batch Totals for Close Batch" mti="0320">
		<field num="1" type="ALPHA" length="4" desc="Message type" />
		<field num="2" type="ALPHA" length="6" desc="STAN" />
		<field num="3" type="ALPHA" length="12" desc="Reserved for future use" />
	</parse>
	<parse id="f60" desc="Batch Totals for Close Batch" mti="0500">
		<field num="1" type="ALPHA" length="6" desc="Message type" />
	</parse>
	
</ISO8583-config>