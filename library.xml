<?xml version="1.0" encoding="BIG5"?>
<project basedir="." default="help" name="Library Build File">
	<import file="base_build.xml"/>
    <property file="library.properties"/>
	<!-- 
	******************************************************************  
	Common Function section begin 
	******************************************************************  
	-->
	<!--
	 - 建立整個專案的library, 並複製到property 'library.dest.dir'所指定之目錄. 呼叫本target前, 必須設定以下property:
	 - 1. library.project.dir : library project所在目錄
	 - 2. library.build.file : library的build file
	 - 3. library.build.target : library build file中用來build library的target
	 - 4. library.dest.dir : library建置後要複製的目的地
	 - 5. library.jar.file : library建置後之檔名.
	 - 6. library.dist.path : library建置後之路徑.
	 -->
	<target name="_do-build-project-library">
		<fail unless="library.jar.file" message="property 'library.jar.path' 尚未設定."/>
		<fail unless="library.dist.path" message="property 'library.jar.path' 尚未設定."/>
		<ant antfile="${library.project.dir}/${library.build.file}" target="${library.build.target}" inheritall="false"/>
		<copy todir="${library.dest.dir}" file="${library.project.dir}/${library.dist.path}/${library.jar.file}" verbose="true"/>
	</target>
	<!--
	 - 建立專案中部份component的library, 並複製到property 'library.dest.dir'所指定之目錄. 呼叫本target前, 必須設定以下property:
	 - 1. library.project.dir : library project所在目錄
	 - 2. library.build.file : library的build file
	 - 3. library.build.target : library build file中用來build library的target
	 - 4. library.dest.dir : library建置後要複製的目的地
	 - 5. library.dest.file : library建置要使用的檔名.
	 - 6. library.compile.files : library建置時所需包含的程式.
	 - 7. library.lib.includes : library建置時所需用到之jar檔(相對於${web.lib.dir}所指之目錄).
	 -->
	<target name="_do-build-component-library">
		<fail unless="library.dest.file" message="property 'library.dest.file' 尚未設定."/>
		<fail unless="library.compile.files" message="property 'library.compile.files' 尚未設定."/>
		<fail unless="library.lib.includes" message="property 'library.lib.includes' 尚未設定."/>
		<path id="component.classpath">
			<fileset dir="${web.lib.dir}" includes="${library.lib.includes}" excludes="${library.lib.excludes}"/>
		</path>
		<ant antfile="${library.project.dir}/${library.build.file}" target="${library.build.target}" inheritall="false">
			<property name="component.files" value="${library.compile.files}"/>
			<property name="component.compile.source" value="${compile.source}"/>
			<property name="component.compile.target" value="${compile.target}"/>
			<property name="component.jar.dest" value="${basedir}/${library.dest.dir}"/>
			<property name="component.jar.file" value="${library.dest.file}"/>
			<reference torefid="component.classpath" refid="component.classpath"/>
		</ant>
	</target>
	<!--
	 - 建立library. 呼叫本target前, 必須設定以下property:
	 - 1. library.project.dir : library project所在目錄
	 - 2. library.build.file : library的build file
	 - 3. library.build.target : library build file中用來build library的target
	 - 4. library.dest.dir : library建置後要複製的目的地
	 - 本target會依property 'build.project' 是否為true來選擇呼叫'_do-build-project-library' 或 '_do-build-component-library',
	 - 該target所需之property請參考其說明
	 -->
	<target name="_do-build-library">
		<fail unless="library.project.dir" message="property 'library.project.dir' 尚未設定."/>
		<fail unless="library.build.file" message="property 'library.build.file' 尚未設定."/>
		<fail unless="library.build.target" message="property 'library.build.target' 尚未設定."/>
		<fail unless="library.dest.dir" message="property 'library.dest.dir' 尚未設定."/>
		<if>
			<istrue value="${build.project}"/>
			<then>
				<runtarget target="_do-build-project-library"/>
			</then>
			<else>
				<runtarget target="_do-build-component-library"/>
			</else>
		</if>
	</target>
	<!--
	 - 本target定義library建置時共用之property的初始化. 主要是給_pre-library-setup-cvs及_pre-library-setup-local呼叫
	 -->
	<target name="_pre-library-setup-common">
		<propertycopy name="library.build.file" from="${library.name}.build.file"/>
		<propertycopy name="library.build.target" from="${library.name}.build.target"/>
		<propertycopy name="library.dest.dir" from="${library.name}.library.dest.dir"/>
		<propertycopy name="library.build.type" from="${library.name}.build.type"/>
		<condition property="build.project" value="true">
			<equals arg1="${library.build.type}" arg2="project" casesensitive="true" trim="true"/>
		</condition>
		<if>
			<istrue value="${build.project}"/>
			<then>
				<propertycopy name="library.dist.path" from="${library.name}.library.path"/>
				<propertycopy name="library.jar.file" from="${library.name}.library.jar"/>
			</then>
			<else>
				<propertycopy name="library.dest.file" from="${library.name}.library.dest.file"/>
				<propertycopy name="library.compile.files" from="${library.name}.compile.files"/>
				<propertycopy name="library.lib.includes" from="${library.name}.lib.includes"/>
				<propertycopy name="library.lib.excludes" from="${library.name}.lib.excludes"/>
			</else>
		</if>
	</target>
	<!--
	 - 執行由CVS建置library時property的初始化.
	 -->
	<target name="_pre-library-setup-cvs">
		<input addproperty="library.name" validargs="${available.library.names}"/>
		<propertycopy name="cvs.server" from="${library.name}.cvs.server"/>
		<propertycopy name="cvs.cvsroot" from="${library.name}.cvs.cvsroot"/>
		<propertycopy name="cvs.module.name" from="${library.name}.cvs.module"/>
		<property name="cvs.temp.dir" value="${library.name}Temp"/>
		<property name="library.project.dir" value="${cvs.temp.dir}/${cvs.module.name}"/>
		<antcallback target="_do-build-cvspass" return="cvspass.file, cvs.account"/>
		<runtarget target="_pre-library-setup-common"/>
	</target>
	<!--
	 - 執行由Local project建置library時property的初始化.
	 -->
	<target name="_pre-library-setup-local">
		<input addproperty="library.name" validargs="${available.library.names}"/>
		<propertycopy name="library.project.dir" from="${library.name}.project.dir"/>
		<runtarget target="_pre-library-setup-common"/>
	</target>
	<target name="upgrade-library-from-cvs"
		description="由CVS建立指定之library目前最新版本的library, 建立後會在cvs加上tag, 並在local端記錄所使用之版本.">
		<runtarget target="_pre-library-setup-cvs"/>
		<var name="keep.cvs.pass.file" value="true"/>
		<trycatch property="exception">
			<try>
				<antcall target="_do-export-from-cvs">
					<param name="cvs.tag.name" value="HEAD"/>
				</antcall>
				<runtarget target="_do-build-library"/>
				<antcallback target="_get-new-tag-name" return="new.tag.name">
					<param name="new.tag.prefix" value="${proj.name}"/>
				</antcallback>
				<runtarget target="_do-tag-module"/>
				<property name="cvs.tag.file" value="${library.name}_tag.version"/>
				<antcallback target="_do-record-cvs-tag" return="new.version.file.created"/>
				<antcall target="_do-check-in-file">
					<param name="cvs.check.in.file" value="${library.dest.dir}/${library.jar.file}"/>
					<param name="cvs.commit.force" value="true"/>
				</antcall>
				<antcall target="_do-check-in-file">
					<param name="cvs.check.in.file" value="${cvs.tag.file}"/>
					<param name="add.file.first" value="${new.version.file.created}"/>
				</antcall>
			</try>
			<finally>
				<var name="keep.cvs.pass.file" value="false"/>
				<runtarget target="_do-cvs-clean-up"/>
			</finally>
		</trycatch>
		<fail message="${exception}" if="exception"/>
	</target>
	<target name="rebuild-library-from-cvs"
		description="根據指定之library的tag version file中所紀錄之current-tag-name, 由CVS建立對應之library.">
		<runtarget target="_pre-library-setup-cvs"/>
		<loadproperties srcfile="${library.name}_tag.version"/>
		<trycatch property="exception">
			<try>
				<antcall target="_do-export-from-cvs">
					<param name="cvs.tag.name" value="${current.tag.name}"/>
				</antcall>
				<runtarget target="_do-build-library"/>
			</try>
			<finally>
				<runtarget target="_do-cvs-clean-up"/>
			</finally>
		</trycatch>
		<fail message="${exception}" if="exception"/>
	</target>
	<target name="rebuild-prev-library-from-cvs"
		description="根據指定之library的tag version file中所紀錄之previous-tag-name, 由CVS建立對應之library.">
		<runtarget target="_pre-library-setup-cvs"/>
		<loadproperties srcfile="${library.name}_tag.version"/>
		<trycatch property="exception">
			<try>
				<antcall target="_do-export-from-cvs">
					<param name="cvs.tag.name" value="${previous.tag.name}"/>
				</antcall>
				<runtarget target="_do-build-library"/>
			</try>
			<finally>
				<runtarget target="_do-cvs-clean-up"/>
			</finally>
		</trycatch>
		<fail message="${exception}" if="exception"/>
	</target>
	<target name="build-library-from-local"
		description="由Local端的project建立指定的library.">
		<runtarget target="_pre-library-setup-local"/>
		<runtarget target="_do-build-library"/>
	</target>
</project>
